#compdef theme-fetch

_theme_fetch() {
  local -a subcmds
  subcmds=(
    'install:Download missing assets, record sha'
    'refresh:Force re-download, update lockfile'
    'verify:Verify cached assets against lockfile'
    'list:List families or variants'
    'help:Show help'
  )

  _arguments -C \
    '1: :->cmd' \
    '*::arg:->args'

  case "$state" in
    cmd)
      _describe -t commands 'theme-fetch command' subcmds
      ;;
    args)
      case "${words[1]}" in
        install|refresh|verify)
          _theme_fetch_pairs
          ;;
        list)
          _theme_fetch_families
          ;;
      esac
      ;;
  esac
}

_theme_fetch_families() {
  local -a families
  families=(${(f)"$(theme-fetch list 2>/dev/null)"})
  _describe -t families 'family' families
}

_theme_fetch_pairs() {
  local -a all_arr
  for family in ${(f)"$(theme-fetch list 2>/dev/null)"}; do
    all_arr+=("$family")
    for variant in ${(f)"$(theme-fetch list "$family" 2>/dev/null)"}; do
      all_arr+=("$family/$variant")
    done
  done
  _describe -t themes 'family or family/variant' all_arr
}

_theme_fetch "$@"
