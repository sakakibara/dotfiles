#compdef dotfiles

_dotfiles() {
  local -a our_subcmds
  our_subcmds=(
    'info:Print info snapshot'
    'install:Run install steps (interactive menu by default)'
    'sync:Review untracked packages'
    'save:Re-add drifted target files'
    'edit:Fuzzy-find a managed file and edit it'
    'profile:Print or switch the active profile'
    'doctor:Health-check the setup'
    'upgrade:Upgrade chezmoi (or every tool with --all)'
    'help:Show help'
  )

  if (( CURRENT == 2 )); then
    # Offer wrapper subcommands first, then chezmoi's own (forwarded
    # subcommands like apply / diff / status / etc.) via the existing
    # _chezmoi completion function. Both lists merge naturally.
    _describe -t commands 'dotfiles command' our_subcmds
    if (( ${+functions[_chezmoi]} )); then
      words[1]=chezmoi
      _chezmoi "$@"
    fi
    return
  fi

  # Per-subcommand argument completion.
  case "${words[2]:-}" in
    install)
      _values 'install step' all none brew mise hive linux extras
      ;;
    edit|save)
      local -a managed
      managed=("${(@f)$(chezmoi managed 2>/dev/null)}")
      _describe 'managed file' managed
      ;;
    profile)
      _values 'profile' personal work
      ;;
    upgrade)
      _values 'flag' --all
      ;;
    sync|doctor|info|help|""|-h|--help)
      ;;
    *)
      # Forward to chezmoi completion for any subcommand we don't own
      # (apply, diff, status, init, …). Cuts off the same way as the
      # wrapper's pass-through case in the bash dispatcher.
      words[1]=chezmoi
      (( ${+functions[_chezmoi]} )) && _chezmoi "$@"
      ;;
  esac
}

_dotfiles "$@"
