#compdef dotfiles

_dotfiles() {
  if (( CURRENT == 2 )); then
    local -a custom_subcmds
    custom_subcmds=(
      'info:Print info snapshot'
      'help:Show help'
    )
    _describe -t commands 'dotfiles command' custom_subcmds
  fi

  case "${words[2]:-}" in
    info|help|""|-h|--help) ;;
    *)
      # Forward to chezmoi completion by pretending the command was chezmoi.
      words[1]=chezmoi
      (( ${+functions[_chezmoi]} )) && _chezmoi "$@"
      ;;
  esac
}

_dotfiles "$@"
