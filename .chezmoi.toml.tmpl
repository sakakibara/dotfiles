{{- $default_profile := env "CHEZMOI_PROFILE" | default "personal" -}}
{{- $profile := promptStringOnce . "profile" "Profile (personal/work)" $default_profile -}}
[data]
email    = "{{ promptStringOnce . "email"    "Email address" }}"
profile  = "{{ $profile }}"
locale   = "{{ promptStringOnce . "locale"   "Locale (e.g., en_US.UTF-8)"          "en_US.UTF-8" }}"
nls_lang = "{{ promptStringOnce . "nls_lang" "Oracle NLS_LANG"                     "AMERICAN_AMERICA.AL32UTF8" }}"
timezone = "{{ promptStringOnce . "timezone" "Timezone (e.g., Japan, US/Eastern)"  "Japan" }}"
{{- if eq $profile "work" }}

# Work signing public key. Public, but kept out of the committed repo so the
# work GitHub account can't be correlated with this personal repo by key
# fingerprint. Merged into `.signing` at runtime alongside the committed
# personal_key.
[data.signing]
work_key = "{{ promptStringOnce . "signing.work_key" "Work signing public key (ssh-ed25519 ...)" }}"

# 1Password locator for the work signing key. Kept out of the committed
# [signing] data because the item/vault names embed an employer identifier;
# these values live only in this local file.
[data.onepassword]
signing_item  = "{{ promptStringOnce . "onepassword.signing_item" "1Password signing-key item name" }}"
signing_vault = "{{ promptStringOnce . "onepassword.signing_vault" "1Password vault" "Private" }}"
{{- end }}
{{- /* Per-account git identities are free-form (can't be prompted), so they
       aren't generated here — but re-emit any existing ones so `chezmoi init`
       never drops them. Add/edit entries by hand; see the generator script
       .chezmoiscripts/run_onchange_after_git-identities.sh.tmpl for the schema. */}}
{{- range (index . "git_identities") }}

[[data.git_identities]]
slug = {{ .slug | quote }}
match_urls = [{{ range $i, $u := .match_urls }}{{ if $i }}, {{ end }}{{ $u | quote }}{{ end }}]
email = {{ .email | quote }}
{{- if (index . "name") }}
name = {{ .name | quote }}
{{- end }}
{{- if (index . "signing_key") }}
signing_key = {{ .signing_key | quote }}
{{- end }}
{{- if (hasKey . "gpgsign") }}
gpgsign = {{ .gpgsign }}
{{- end }}
{{- end }}
