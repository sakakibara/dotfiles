{{/* holt workspace config. The storage backend is per-machine (see
     holt_backend in .chezmoi.toml.tmpl): this laptop syncs via iCloud, another
     via Google Drive, and a plain machine uses a local folder. synced_root is
     the cloud-synced folder holt keeps projects/ (and archive/, backups/)
     under; code_root and hub_root are machine-local. Only the active backend's
     preset is emitted, since holt only needs the one it resolves.
     Read the backend through `get` with a default so this still renders where
     the per-machine data is absent (e.g. CI's bare execute-template). */ -}}
{{- $backend := get . "holt_backend" | default "local" -}}
{{- $gdrive_account := get . "gdrive_account" | default "" -}}
[workspace]
{{- if eq $backend "icloud" }}
backend   = "icloud"
{{- else if eq $backend "gdrive" }}
backend   = "gdrive"
{{- else }}
synced_root = "~/workspace"
{{- end }}
code_root = "~/Code"
hub_root  = "~/Projects"
{{ if eq $backend "icloud" }}
[backends.icloud]
synced_root = "~/Library/Mobile Documents/com~apple~CloudDocs/workspace"
{{- else if eq $backend "gdrive" }}
[backends.gdrive]
synced_root = "~/Library/CloudStorage/GoogleDrive-{{ $gdrive_account }}/マイドライブ/workspace"
{{- end }}
