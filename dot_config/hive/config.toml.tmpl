[paths]
projects = "~/Projects"
life = "~/Life"
work = "~/Work"
archive = "~/Archive"
code = "~/Code"

[storage]
{{- if eq ((index . "profile") | default "personal") "personal" }}
mode = "icloud"
icloud_root = "~/Library/Mobile Documents/com~apple~CloudDocs/workspace"
{{- else }}
mode = "local"
{{- end }}
