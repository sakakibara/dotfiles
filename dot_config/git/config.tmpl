{{ $proxy_url := "" -}}
{{ $proxy_envs := list
     "http_proxy"
     "https_proxy"
     "HTTP_PROXY"
     "HTTPS_PROXY" -}}
{{ range $proxy_envs -}}
{{   if env . -}}
{{     $proxy_url = env . -}}
{{     break -}}
{{   end -}}
{{ end -}}

{{/* Machine-default signing key follows the profile. Personal-account repos
     override this (and the email) via the [includeIf] blocks at the end. */ -}}
{{ $signing_key := .signing.personal_key -}}
{{ if eq (index . "profile" | default "personal") "work" -}}
{{   $signing_key = .signing.work_key -}}
{{ end -}}

[init]
	defaultBranch = main
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[core]
	autocrlf = input
	whitespace = fix,space-before-tab,tab-in-indent,trailing-space
[apply]
	whitespace = fix
[push]
	default = simple
[pull]
	rebase = true
[alias]
	br = branch
	ci = commit
	co = checkout
	df = diff
	g = grep -I
	lg = log -p
	rb = rbranch
	rv = review
	st = status
[color]
	ui = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[merge]
	log = true
	tool = nvimdiff
[mergetool]
	prompt = true
[mergetool "nvimdiff"]
	cmd = nvim -d $BASE $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'
[user]
	name = Sho Sakakibara
{{- if (index . "email") }}
	email = {{ .email }}
{{- end }}
{{- if $signing_key }}
	signingkey = {{ $signing_key }}
{{- end }}
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
{{- if $signing_key }}
[gpg]
	format = ssh
[gpg "ssh"]
{{- if eq .chezmoi.os "darwin" }}
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
{{- else if eq .chezmoi.os "linux" }}
	program = /opt/1Password/op-ssh-sign
{{- else if eq .chezmoi.os "windows" }}
	program = "C:/Users/{{ .chezmoi.username }}/AppData/Local/1Password/app/8/op-ssh-sign.exe"
{{- end }}
	allowedSignersFile = ~/.config/git/allowed_signers
[commit]
	gpgsign = true
[tag]
	gpgsign = true
{{- end }}

{{- if ne $proxy_url "" }}
[http]
	proxy = {{ $proxy_url }}
[https]
	proxy = {{ $proxy_url }}
{{- end }}

# Personal-account repos, detected by their GitHub remote URL, override the
# machine-default identity and signing key above with the personal ones — so
# personal repos never need a per-repo .git/config. Work stays the unnamed
# default, keeping the employer org out of this committed file. (Matching is
# by remote, so add the remote before your first commit in a fresh repo.)
[includeIf "hasconfig:remote.*.url:https://github.com/sakakibara/**"]
	path = ~/.config/git/personal.inc
[includeIf "hasconfig:remote.*.url:git@github.com:sakakibara/**"]
	path = ~/.config/git/personal.inc
[includeIf "hasconfig:remote.*.url:ssh://git@github.com/sakakibara/**"]
	path = ~/.config/git/personal.inc

# Additional work/client identities (a different email, name, and/or signing
# key per GitHub org) are employer-specific, so they live in a local include
# generated from the [[data.git_identities]] array in your local chezmoi
# config — never committed here. A missing file is silently ignored by git.
[include]
	path = ~/.config/git/identities.local.inc
