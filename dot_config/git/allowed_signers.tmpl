{{- /*
   Trusted SSH public keys for verifying commit signatures locally.
   Format: <principal-pattern> namespaces=<list> <key-type> <key>
   See `man ssh-keygen` ALLOWED SIGNERS section.

   Lists every account whose commits this machine may need to verify: the
   personal account always, plus the work account on work machines (the work
   email comes from local data and is never committed). Empty when no keys
   are configured; git tolerates an empty allowedSignersFile.
*/ -}}
{{- if .signing.personal_key -}}
sho@sakakibara.dev namespaces="git" {{ .signing.personal_key }}
{{ end -}}
{{- if and (eq (index . "profile" | default "personal") "work") .signing.work_key (index . "email") -}}
{{ index . "email" }} namespaces="git" {{ .signing.work_key }}
{{ end -}}
