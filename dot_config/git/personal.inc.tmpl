{{- /* Personal-account git identity. Pulled in by ~/.gitconfig's [includeIf]
   blocks for any repo whose remote is github.com/sakakibara/*. Sets the
   personal email and signing key together, so personal repos need no
   per-repo .git/config — set once here, applied everywhere by remote.
   gpg.format/program/allowedSignersFile and commit.gpgsign come from the
   machine-default block in .gitconfig and apply unchanged. */ -}}
[user]
	email = sho@sakakibara.dev
{{- if .signing.personal_key }}
	signingkey = {{ .signing.personal_key }}
{{- end }}
# Read by ~/.config/git/account-token (gh shim, credential helper, and the
# mise env on Windows) to pick the GitHub account for `gh` and HTTPS git in
# personal repos. The login is already public in this file's [includeIf]
# glob, so it is fine to commit.
[github]
	account = sakakibara
