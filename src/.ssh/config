# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

# Vagrant private-network VMs. StrictHostKeyChecking=no is appropriate
# here because vagrant VMs are ephemeral and their host keys legitimately
# churn on every `vagrant destroy && up`. UserKnownHostsFile=/dev/null
# keeps known_hosts from filling with throwaway entries.
Host 192.168.33.* *.loc
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  LogLevel ERROR
# mox: when use_1password_ssh_agent=true
  # Vagrant uses its own per-VM keys, not 1Password's vault. Disable
  # the agent for these hosts so ssh falls back to IdentityFile lookup.
  IdentityAgent none
# mox: end

# Catch-all defaults. Specific Host blocks above take precedence per
# SSH's first-match-wins rule.
Host *
  # `accept-new` (OpenSSH 7.6+) auto-adds first-connect host keys but
  # still rejects changed keys. The blanket `no` we used previously
  # silently accepted MITM, which is what `accept-new` fixes.
  StrictHostKeyChecking accept-new
  AddKeysToAgent yes
  ServerAliveInterval 60
# mox: when use_1password_ssh_agent=true and os=darwin
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
# mox: end
# mox: when use_1password_ssh_agent=true and os=linux
  IdentityAgent ~/.1password/agent.sock
# mox: end
# mox: when use_1password_ssh_agent=true and os=windows
  IdentityAgent \\.\pipe\openssh-ssh-agent
# mox: end
