[init]
	defaultBranch = main
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[core]
	autocrlf = input
	whitespace = fix,space-before-tab,tab-in-indent,trailing-space
[apply]
	whitespace = fix
[push]
	default = simple
[pull]
	rebase = true
[alias]
	br = branch
	ci = commit
	co = checkout
	df = diff
	g = grep -I
	lg = log -p
	rb = rbranch
	rv = review
	st = status
[color]
	ui = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[merge]
	log = true
	tool = nvimdiff
[mergetool]
	prompt = true
[mergetool "nvimdiff"]
	cmd = nvim -d $BASE $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'
[user]
	name = Sho Sakakibara
# mox: when email
	email = <machine.email>
# mox: end
# mox: when not profile=work
	signingkey = <data.signing.personal_key>
# mox: end
# mox: when profile=work and signing_work_key
	signingkey = <machine.signing_work_key>
# mox: end
# The helper resolves the per-repo account token itself (account-token reads
# `github.account`, set by the [includeIf] routing below), at auth time and
# in git's own cwd -- so HTTPS picks the right account in any context,
# including processes that never ran a shell hook (editors, agents,
# scripts). Empty resolution (unmapped repo, missing script) leaves GH_TOKEN
# empty and gh falls back to its active account. Windows included: git runs
# `!` helpers under its bundled sh, which executes the same bash script.
[credential "https://github.com"]
	helper =
	helper = !GH_TOKEN=$(~/.config/git/account-token 2>/dev/null || true) gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !GH_TOKEN=$(~/.config/git/account-token 2>/dev/null || true) gh auth git-credential
# Route every GitHub remote over HTTPS at transport time, whatever protocol it
# is written in, so per-account auth always flows through the credential
# helper's per-repo token. This rewrites the URL used to connect
# only — the stored remote is untouched, so the [includeIf] rules below still
# match the original git@/ssh:// form. Without it, an SSH remote would pick the
# account by whichever key 1Password offers first, not by repo. Need real SSH
# transport for a specific repo? Override that remote's URL locally.
[url "https://github.com/"]
	insteadOf = git@github.com:
	insteadOf = ssh://git@github.com/
[gpg]
	format = ssh
[gpg "ssh"]
# mox: when os=darwin
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
# mox: end
# mox: when os=linux
	program = /opt/1Password/op-ssh-sign
# mox: end
# mox: when os=windows
	program = "C:/Users/<machine.username>/AppData/Local/1Password/app/8/op-ssh-sign.exe"
# mox: end
	allowedSignersFile = ~/.config/git/allowed_signers
[commit]
	gpgsign = true
[tag]
	gpgsign = true

# Personal-account repos, detected by their GitHub remote URL, override the
# machine-default identity and signing key above with the personal ones — so
# personal repos never need a per-repo .git/config. Work stays the unnamed
# default, keeping the employer org out of this committed file. (Matching is
# by remote, so add the remote before your first commit in a fresh repo.)
[includeIf "hasconfig:remote.*.url:https://github.com/sakakibara/**"]
	path = ~/.config/git/personal.inc
[includeIf "hasconfig:remote.*.url:git@github.com:sakakibara/**"]
	path = ~/.config/git/personal.inc
[includeIf "hasconfig:remote.*.url:ssh://git@github.com/sakakibara/**"]
	path = ~/.config/git/personal.inc

# Additional work/client identities (a different email, name, and/or signing
# key per GitHub org) are employer-specific, so they live in a local include
# generated from the git_identities array in your local mox private data --
# never committed here. A missing file is silently ignored by git.
[include]
	path = ~/.config/git/identities.local.inc
