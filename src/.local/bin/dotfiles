#!/usr/bin/env bash
# dotfiles -- mox wrapper with status snapshot.
#
# `dotfiles` (no args) or `dotfiles info` prints a snapshot of the
# deployment: source dir, git state, mox drift, theme, tool versions.
# Any other invocation forwards to `mox` via `exec`. Some subcommands
# (currently `cd`) are overridden by shell-function wrappers in .zfunc/
# and .config/fish/functions/ to operate on the calling shell directly.

set -euo pipefail

# ANSI color helpers — only when stdout is a TTY.
if [[ -t 1 ]]; then
  C_DIM=$'\033[2m'
  C_BOLD=$'\033[1m'
  C_RESET=$'\033[0m'
else
  C_DIM=""
  C_BOLD=""
  C_RESET=""
fi

_row() {
  printf '%s%-7s%s %s\n' "$C_BOLD" "$1" "$C_RESET" "$2"
}

_version_of() {
  local out
  out=$("$1" --version 2>&1 | head -n1) || return 1
  printf '%s' "$out" | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -n1
}

_mox_repo() {
  printf '%s' "${MOX_REPO:-${XDG_DATA_HOME:-$HOME/.local/share}/mox/dotfiles}"
}

cmd_info() {
  local source_dir
  source_dir=$(_mox_repo)
  [[ -n "$source_dir" ]] && _row "Repo:" "$source_dir"

  if [[ -n "$source_dir" && -d "$source_dir/.git" ]]; then
    local branch ahead behind
    branch=$(git -C "$source_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
    ahead=$(git -C "$source_dir" rev-list --count "@{u}..HEAD" 2>/dev/null || echo 0)
    behind=$(git -C "$source_dir" rev-list --count "HEAD..@{u}" 2>/dev/null || echo 0)
    _row "Branch:" "$branch (ahead $ahead, behind $behind)"
  fi

  if command -v mox >/dev/null 2>&1; then
    local status_out drift
    status_out=$(mox status 2>/dev/null || true)
    drift=$(printf '%s\n' "$status_out" | awk 'NF && $1 != "clean" && $1 != "GATED"')
    if [[ -z "$drift" ]]; then
      _row "Drift:" "none"
    else
      local count
      count=$(printf '%s\n' "$drift" | wc -l | tr -d ' ')
      _row "Drift:" "$count file(s)"
      # List each drifted entry on its own indented line. `mox status` emits
      # `  <state>  <path>` per managed file; non-clean, non-GATED states are
      # the drift. 8 leading spaces aligns with the _row value column.
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        printf '        %s%s%s\n' "$C_DIM" "${line#  }" "$C_RESET"
      done <<<"$drift"
    fi
  fi

  if command -v theme >/dev/null 2>&1; then
    _row "Theme:" "$(theme get 2>/dev/null || echo "?")"
  fi

  local tools=(mox nvim fish zsh mise brew holt theme starship)
  local versions=()
  for t in "${tools[@]}"; do
    command -v "$t" >/dev/null 2>&1 || continue
    local v
    v=$(_version_of "$t" 2>/dev/null || echo "")
    if [[ -n "$v" ]]; then
      versions+=("$t $v")
    else
      versions+=("$t")
    fi
  done
  if (( ${#versions[@]} > 0 )); then
    _row "Tools:" "${C_DIM}${versions[*]}${C_RESET}"
  fi
}

cmd_help() {
  cat <<EOF
dotfiles -- mox wrapper with status snapshot

Usage:
  dotfiles                  Print info snapshot (default)
  dotfiles info             Same as default
  dotfiles install          Interactive menu to (re)run install steps
  dotfiles install all      Run every install step non-interactively
  dotfiles install <names>  Run only the named steps (e.g. brew mise)
  dotfiles sync             Review untracked packages and add/blacklist them
  dotfiles edit <pattern>   Fuzzy-find a managed file and edit via mox
  dotfiles profile [name]   Print or switch the active mox profile
  dotfiles doctor           Health-check the dotfiles + mox setup
  dotfiles upgrade [--all]  Upgrade managed tools (brew, mise, holt) with --all
  dotfiles <cmd>            Forward to mox (e.g. dotfiles apply, dotfiles diff)
  dotfiles --help           Show this help

Shell-function overrides (active in zsh and fish):
  dotfiles cd               cd current shell to mox repo dir
  dotfiles apply            Re-source shell rc file on successful apply

For mox-specific help: mox --help
EOF
}

# Hash a single file with sha256. Empty output for missing files.
_hash_file() {
  local f="$1"
  [[ -r "$f" ]] || { printf ''; return; }
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$f" | awk '{print $1}'
  else
    shasum -a 256 "$f" 2>/dev/null | awk '{print $1}'
  fi
}

cmd_edit() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
dotfiles edit -- fuzzy-find a managed file and open it via mox edit.

Usage:
  dotfiles edit <pattern>    Open managed file matching pattern in $EDITOR

Pattern is a case-insensitive substring of the path (relative to $HOME).
Exactly-one match opens directly; multiple matches prompt to pick by number.
Opens the source behind the managed path; run `mox apply` to write it live.
EOF
      return 0
      ;;
  esac

  local pattern="${1:-}"
  if [[ -z "$pattern" ]]; then
    printf 'usage: dotfiles edit <pattern>\n' >&2
    return 1
  fi

  command -v mox >/dev/null 2>&1 || {
    printf 'dotfiles edit: mox not on PATH\n' >&2
    return 1
  }

  local matches=() rel
  while IFS= read -r rel; do
    [[ -z "$rel" ]] && continue
    matches+=("$rel")
  done < <(mox status 2>/dev/null | sed -E 's/^  [A-Za-z]+ +//' | sed "s#^$HOME/##" | grep -iF -- "$pattern" || true)

  case ${#matches[@]} in
    0)
      printf 'no managed file matches %q\n' "$pattern" >&2
      return 1
      ;;
    1)
      mox edit "$HOME/${matches[0]}"
      ;;
    *)
      printf 'multiple matches:\n'
      local i
      for ((i=0; i<${#matches[@]}; i++)); do
        printf '  %s%2d)%s %s\n' "$C_BOLD" "$((i+1))" "$C_RESET" "${matches[i]}"
      done
      local pick
      printf 'pick (1-%d, q to cancel): ' "${#matches[@]}"
      IFS= read -r pick </dev/tty || return 1
      [[ "$pick" == q || "$pick" == Q ]] && return 0
      [[ "$pick" =~ ^[0-9]+$ ]] || { printf 'not a number\n' >&2; return 1; }
      (( pick < 1 || pick > ${#matches[@]} )) && { printf 'out of range\n' >&2; return 1; }
      mox edit "$HOME/${matches[$((pick-1))]}"
      ;;
  esac
}

cmd_profile() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
dotfiles profile -- print or change the active mox profile.

Usage:
  dotfiles profile           Print the current profile
  dotfiles profile <name>    Switch profile and re-apply

Switching writes the `profile` fact (`mox facts set profile <name>`) and then
runs `mox apply`. All profile-gated content (packages.txt entries, holt
config, role.lua, ...) re-renders accordingly.
EOF
      return 0
      ;;
  esac

  command -v mox >/dev/null 2>&1 || {
    printf 'dotfiles profile: mox not on PATH\n' >&2
    return 1
  }

  if [[ -z "${1:-}" ]]; then
    local current
    current=$(mox facts </dev/null 2>/dev/null | awk -F' = ' '$1 == "profile" { gsub(/"/, "", $2); print $2 }' || true)
    printf '%s\n' "${current:-personal}"
    return 0
  fi

  local target="$1"
  case "$target" in
    personal|work) ;;
    *)
      printf 'unknown profile: %q (expected one of: personal, work)\n' "$target" >&2
      return 1
      ;;
  esac

  printf 'Switching to profile: %s%s%s\n' "$C_BOLD" "$target" "$C_RESET"
  mox facts set profile "$target" || return 1
  mox apply
}

cmd_doctor() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
dotfiles doctor -- health check for the dotfiles + mox setup.

Verifies that the mox binary is reachable, the repo resolves, the profile
resolves, package files parse, the theme state file is intact, and the
OS-specific install lib (brew or linux) is usable. Exits 0 when all checks
pass, 1 if any failed.
EOF
      return 0
      ;;
  esac

  # Doctor relies on bare `[[ … ]]` tests to detect failures; set -e would
  # exit on the first negative test before _check could record it.
  set +e +u +o pipefail

  local fails=0 passes=0
  local pass_glyph="${C_BOLD}$(printf '\033[1;32m')✓$(printf '\033[0m')"
  local fail_glyph="${C_BOLD}$(printf '\033[1;31m')✖$(printf '\033[0m')"
  _check() {
    local desc="$1" rc="$2" detail="${3:-}"
    if (( rc == 0 )); then
      printf '  %b %s\n' "$pass_glyph" "$desc"
      passes=$((passes + 1))
    else
      printf '  %b %s%s%s\n' "$fail_glyph" "$desc" \
        "${detail:+ ${C_DIM}(}" \
        "${detail:+${detail}${C_RESET})}"
      fails=$((fails + 1))
    fi
  }

  printf '%sChecks%s\n' "$C_BOLD" "$C_RESET"

  command -v mox >/dev/null 2>&1
  _check "mox on PATH" $?

  local source_dir
  source_dir=$(_mox_repo)
  [[ -n "$source_dir" && -d "$source_dir" ]]
  _check "mox repo resolves to a directory" $?

  local profile=""
  if command -v mox >/dev/null 2>&1; then
    profile=$(mox facts </dev/null 2>/dev/null | awk -F' = ' '$1 == "profile" { gsub(/"/, "", $2); print $2 }' || true)
  fi
  [[ -n "$profile" ]]
  _check "profile resolves" $? "$profile"

  if [[ -n "$source_dir" ]]; then
    bash -n "$source_dir/etc/bash/lib/init.bash" 2>/dev/null
    _check "etc/bash/lib/init.bash parses" $?
  fi

  # OS-specific package list
  local os pkg_file
  case "$(uname -s)" in
    Darwin) os=darwin; pkg_file="$source_dir/etc/darwin/packages.txt" ;;
    Linux)
      os=linux
      if [[ -n "$source_dir" ]] && command -v mox >/dev/null 2>&1; then
        # Source linux.bash to get distro detection
        # shellcheck disable=SC1091
        ( source "$source_dir/etc/bash/lib/init.bash"; import linux; linux::detect_distro ) >/dev/null 2>&1
        _check "linux distro detection" $?
        local distro
        distro=$( source "$source_dir/etc/bash/lib/init.bash"; import linux; linux::detect_distro 2>/dev/null )
        pkg_file="$source_dir/etc/linux/packages-${distro}.txt"
      fi
      ;;
    *) os=other ;;
  esac

  if [[ -n "$pkg_file" ]]; then
    [[ -r "$pkg_file" ]]
    _check "package list readable" $? "$pkg_file"
  fi

  # Theme command works (state file may legitimately not exist before the
  # user explicitly runs `theme set`; `theme get` then resolves via the
  # manifest defaults).
  if command -v theme >/dev/null 2>&1; then
    theme get >/dev/null 2>&1
    _check "theme get resolves a current family/variant" $?
  fi

  # Per-OS toolchain reachability
  case "$os" in
    darwin)
      command -v brew >/dev/null 2>&1
      _check "brew on PATH" $?
      ;;
    linux)
      command -v sudo >/dev/null 2>&1
      _check "sudo on PATH" $?
      ;;
  esac
  command -v mise >/dev/null 2>&1
  _check "mise on PATH" $?
  command -v holt >/dev/null 2>&1
  _check "holt on PATH" $?

  printf '\n%d passed, %d failed\n' "$passes" "$fails"
  return "$fails"
}

cmd_upgrade() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
dotfiles upgrade -- bring managed tools up to date.

Usage:
  dotfiles upgrade           Explain that mox has no self-upgrade
  dotfiles upgrade --all     brew + mise + holt

mox installs as a release binary and has no self-upgrade; `--all` runs the
upgrade gestures for each managed tool in dependency order. On Linux it
deliberately SKIPS distro package upgrade (`dnf upgrade` etc.) --
kernel/service implications make that a manual gesture.
EOF
      return 0
      ;;
    "")
      printf 'mox installs as a release binary; there is no self-upgrade.\n'
      printf 'Use `dotfiles upgrade --all` to upgrade managed tools (brew, mise, holt).\n'
      return 0
      ;;
    --all)
      _upgrade_all
      return $?
      ;;
    *)
      printf 'unknown flag: %q\n' "$1" >&2
      printf 'try: dotfiles upgrade --help\n' >&2
      return 1
      ;;
  esac
}

_upgrade_all() {
  local fails=0
  _step() {
    printf '\n%s== %s ==%s\n' "$C_BOLD" "$1" "$C_RESET"
    shift
    "$@" || fails=$((fails + 1))
  }

  case "$(uname -s)" in
    Darwin)
      command -v brew >/dev/null 2>&1 && _step "brew" brew upgrade
      ;;
    Linux)
      printf '\n%s== distro packages ==%s\n  ' "$C_BOLD" "$C_RESET"
      printf '%sskipped (run `sudo dnf upgrade` / `sudo apt upgrade` etc. manually)%s\n' \
        "$C_DIM" "$C_RESET"
      ;;
  esac

  command -v mise >/dev/null 2>&1 && _step "mise (self)"  mise self-update
  command -v mise >/dev/null 2>&1 && _step "mise (tools)" mise upgrade
  command -v holt >/dev/null 2>&1 && _step "holt"         holt upgrade

  printf '\n'
  if (( fails == 0 )); then
    printf '%s✓%s all upgrade steps succeeded\n' "${C_BOLD}$(printf '\033[1;32m')" "$C_RESET"
  else
    printf '%s✖%s %d step(s) failed\n' "${C_BOLD}$(printf '\033[1;31m')" "$C_RESET" "$fails"
  fi
  return "$fails"
}

cmd_install() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
dotfiles install — interactive multi-select runner for install steps.

Usage:
  dotfiles install                  Open the menu (pre-checks items whose
                                    inputs have changed since the last run)
  dotfiles install all              Run every step non-interactively
  dotfiles install none             Run only required steps (skip everything else)
  dotfiles install <name> <name>…   Run the named steps (e.g. brew mise)

Inside the menu:
  ↑/↓ navigate · ←/→ jump column · space toggle · a/n select all/none
  / filter · enter run · q/esc cancel · ? help
EOF
      return 0
      ;;
  esac

  local os
  case "$(uname -s)" in
    Darwin) os=darwin ;;
    Linux)  os=linux  ;;
    *) printf 'dotfiles install: unsupported OS %s\n' "$(uname -s)" >&2; return 1 ;;
  esac

  local source_dir
  source_dir=$(_mox_repo)
  if [[ ! -r "$source_dir/etc/bash/lib/init.bash" ]]; then
    printf 'dotfiles install: source dir lacks expected lib (%s)\n' "$source_dir" >&2
    return 1
  fi

  # The lib functions weren't written for `set -euo pipefail`. Relax for
  # the duration of this command.
  set +e +u +o pipefail

  # shellcheck disable=SC1091
  source "$source_dir/etc/bash/lib/init.bash"
  case "$os" in
    darwin) import unix darwin brew mise holt pick ;;
    linux)  import unix linux mise extras holt pick ;;
  esac

  unix::keep_sudo

  # Translate positional args into DOTFILES_PICK so a non-interactive call
  # (e.g. `dotfiles install brew mise`) skips the menu and runs immediately.
  if (( $# > 0 )); then
    case "$1" in
      all|none) export DOTFILES_PICK="$1" ;;
      *)
        local IFS=','
        export DOTFILES_PICK="$*"
        ;;
    esac
  fi

  local mise_h holt_h
  mise_h=$(_hash_file "$source_dir/src/.config/mise/config.toml")
  holt_h=$(_hash_file "$source_dir/src/.config/holt/config.toml")

  local items=()
  case "$os" in
    darwin)
      darwin::require_clt || return 1
      local brew_h
      brew_h=$(_hash_file "$source_dir/etc/darwin/Brewfile")
      items=(
        "==Packages"
        "brew::setup=Homebrew packages & casks|$brew_h"
        "==Toolchains"
        "mise::setup=Language toolchains via mise|$mise_h"
        "==Workspace"
        "holt::setup=Workspace symlinks (holt)|$holt_h"
      )
      ;;
    linux)
      local distro pkg_file linux_h extras_h
      distro=$(linux::distro 2>/dev/null || echo unknown)
      pkg_file="$source_dir/etc/linux/packages-${distro}.txt"
      linux_h=$(_hash_file "$pkg_file")
      extras_h=$(_hash_file "$source_dir/etc/bash/lib/extras.bash")
      items=(
        "==Packages"
        "linux::setup=System packages (${distro})|$linux_h"
        "extras::setup=Bucket-3 tools (starship, gh, lazygit, …)|$extras_h"
        "==Toolchains"
        "mise::setup=Language toolchains via mise|$mise_h"
        "==Workspace"
        "holt::setup=Workspace symlinks (holt)|$holt_h"
      )
      ;;
  esac

  DOTFILES_PICK_SCOPE="install" pick "${items[@]}"
}

cmd_sync() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
dotfiles sync — review installed-but-untracked packages.

Diffs the system package manager's current state against
etc/<os>/packages.txt (and packages-blacklist.txt). For each untracked
entry, opens an interactive TUI where you assign one action per row:

  skip   — leave it alone
  add    — append `kind:name` to packages.txt (no profile annotation)
  @prof  — append `kind:name @profile` (profile-gated)
  block  — append to packages-blacklist.txt (sync won't surface again)

Inside the menu:
  ↑/↓ navigate · space cycle · a add · p add @personal · w add @work
  b blacklist · s skip · enter apply · q cancel · ? help
EOF
      return 0
      ;;
  esac

  local source_dir
  source_dir=$(_mox_repo)
  set +e +u +o pipefail
  # shellcheck disable=SC1091
  source "$source_dir/etc/bash/lib/init.bash"
  import sync
  sync::run
}

case "${1:-}" in
  ""|info)
    shift 2>/dev/null || true
    cmd_info "$@"
    ;;
  -h|--help)
    cmd_help
    ;;
  install)
    shift
    cmd_install "$@"
    ;;
  sync)
    shift
    cmd_sync "$@"
    ;;
  edit)
    shift
    cmd_edit "$@"
    ;;
  doctor)
    shift
    cmd_doctor "$@"
    ;;
  profile)
    shift
    cmd_profile "$@"
    ;;
  upgrade)
    shift
    cmd_upgrade "$@"
    ;;
  help)
    if [[ $# -eq 1 ]]; then cmd_help; else exec mox "$@"; fi
    ;;
  *)
    # Flags pass through unchecked (e.g. mox --version). For bare
    # subcommands, probe `mox help <name>` first so typos surface a
    # dotfiles-aware error instead of silently routing to mox.
    if [[ "$1" == -* ]] || mox help "$1" >/dev/null 2>&1; then
      exec mox "$@"
    else
      printf 'dotfiles: unknown subcommand %q\n' "$1" >&2
      printf 'see `dotfiles --help` (wrapper) or `mox --help` (forwarded)\n' >&2
      exit 1
    fi
    ;;
esac
