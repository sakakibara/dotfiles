{{- if eq .chezmoi.os "windows" -}}
# Keep ~/.local/bin at the front of the user Path so the gh shim there
# shadows the real gh (scoop's shim dir sits later in the user Path). The
# user Path is registry-persisted, so every new shell and GUI process
# inherits the order. Idempotent: moves the entry to the front if present,
# adds it if missing. Machine-scope installs (system Path) always precede
# the user Path and would still win; gh comes from scoop, which is
# user-scope.

$ErrorActionPreference = 'Stop'
$bin = Join-Path $HOME '.local\bin'
$cur = [Environment]::GetEnvironmentVariable('Path', 'User')
$parts = @(($cur -split ';') | Where-Object { $_ -and $_ -ne $bin })
[Environment]::SetEnvironmentVariable('Path', (@($bin) + $parts) -join ';', 'User')
{{- end -}}
