{{ if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
# Hash trigger — re-runs when the hive config or the hive lib changes.
# hive config hash: {{ include "dot_config/hive/config.toml.tmpl" | sha256sum }}
# Hive.psm1 hash:   {{ include "etc/powershell/lib/Hive.psm1"    | sha256sum }}

$ErrorActionPreference = 'Stop'
$env:CHEZMOI_SOURCE_DIR = '{{ .chezmoi.sourceDir }}'

Import-Module (Join-Path $env:CHEZMOI_SOURCE_DIR 'etc/powershell/lib/Hive.psm1') -Force
exit (Install-Hive)
{{ end -}}
