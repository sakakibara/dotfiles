{{ if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
# Hash trigger — re-runs when the hive config or the hive lib changes.
# hive config hash: {{ include "dot_config/hive/config.toml.tmpl" | sha256sum }}
# hive.ps1 hash:    {{ include "etc/powershell/lib/hive.ps1"     | sha256sum }}

$ErrorActionPreference = 'Stop'
$env:CHEZMOI_SOURCE_DIR = '{{ .chezmoi.sourceDir }}'

. (Join-Path $env:CHEZMOI_SOURCE_DIR 'etc/powershell/lib/hive.ps1')
exit (Install-Hive)
{{ end -}}
