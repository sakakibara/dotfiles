{{ if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
# Hash trigger — re-runs whenever any of the comment hashes below change.
# packages.txt hash:    {{ include "etc/windows/packages.txt"           | sha256sum }}
# blacklist hash:       {{ include "etc/windows/packages-blacklist.txt" | sha256sum }}

$ErrorActionPreference = 'Stop'
$DOTFILES_PROFILE = '{{ (index . "profile") | default "personal" }}'

function _Heading([string]$msg) { Write-Host ''; Write-Host ('==> ' + $msg) }
function _Arrow([string]$msg)   { Write-Host ('  -> ' + $msg) }
function _Error([string]$msg)   { [Console]::Error.WriteLine('  ✖ ' + $msg) }

# ---------- packages.txt parser (mirrors _SyncParseLine in sync.ps1) ----------
function _ParseLine([string]$line) {
    $line = ($line -replace '#.*$', '').Trim()
    if (-not $line) { return $null }
    $profiles = @()
    $lastSpaceAt = $line.LastIndexOf(' @')
    if ($lastSpaceAt -ge 0) {
        $profilePart = $line.Substring($lastSpaceAt + 2)
        $line = $line.Substring(0, $lastSpaceAt).Trim()
        $profiles = @($profilePart -split ',' | ForEach-Object { $_.Trim() } | Where-Object { $_ })
    }
    $kind = ''; $name = $line
    if ($line -match '^([a-z]+):(.*)$') { $kind = $matches[1]; $name = $matches[2] }
    return @{ Kind = $kind; Name = $name; Profiles = $profiles }
}

function _AppliesTo([hashtable]$p) {
    if ($p.Profiles.Count -eq 0) { return $true }
    return ($p.Profiles -contains $DOTFILES_PROFILE)
}

function _ReadPackages([string]$file, [string]$default_kind) {
    if (-not (Test-Path -LiteralPath $file)) { return @() }
    $out = @()
    foreach ($line in Get-Content -LiteralPath $file) {
        $p = _ParseLine $line
        if (-not $p) { continue }
        if (-not (_AppliesTo $p)) { continue }
        $k = if ($p.Kind) { $p.Kind } else { $default_kind }
        $out += @{ Kind = $k; Name = $p.Name }
    }
    return ,$out
}

# ---------- bootstrap scoop ----------
_Heading 'scoop bootstrap'
if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
    _Arrow 'scoop missing — installing via the official script'
    [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
    Invoke-RestMethod -Uri 'https://get.scoop.sh' | Invoke-Expression
    if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
        _Error 'scoop install failed'
        exit 1
    }
}
_Arrow 'scoop is installed'

# ---------- read package list ----------
$pkgFile = '{{ joinPath .chezmoi.sourceDir "etc/windows/packages.txt"           }}'
$blFile  = '{{ joinPath .chezmoi.sourceDir "etc/windows/packages-blacklist.txt" }}'
$packages  = _ReadPackages $pkgFile 'scoop'
$blacklist = _ReadPackages $blFile  'scoop'

# Exclude blacklisted entries.
$blockedKey = @{}
foreach ($e in $blacklist) { $blockedKey["$($e.Kind):$($e.Name)"] = $true }
$packages = @($packages | Where-Object { -not $blockedKey.ContainsKey("$($_.Kind):$($_.Name)") })

if ($packages.Count -eq 0) {
    _Arrow 'no packages declared for this profile — done'
    exit 0
}

# ---------- ensure required scoop buckets are added ----------
$bucketEntries = @($packages | Where-Object { $_.Kind -eq 'bucket' })
if ($bucketEntries.Count -gt 0) {
    _Heading 'scoop buckets'
    $existing = @((& scoop bucket list 2>$null) | ForEach-Object { ($_ -split '\s+')[0] } | Where-Object { $_ -and $_ -ne 'Name' })
    foreach ($b in $bucketEntries) {
        if ($existing -contains $b.Name) {
            _Arrow ("$($b.Name) (already added)")
        } else {
            _Arrow ("adding bucket $($b.Name)")
            & scoop bucket add $b.Name
        }
    }
}

# ---------- diff installed vs declared, install missing ----------
function _ScoopInstalledNames {
    $raw = & scoop export 2>$null | Out-String
    if (-not $raw) { return @{} }
    try { $data = $raw | ConvertFrom-Json -ErrorAction Stop } catch { return @{} }
    $names = @{}
    foreach ($app in $data.apps) {
        $names[$app.Name] = $true
        if ($app.Source -and $app.Source -ne 'main') {
            $names["$($app.Source)/$($app.Name)"] = $true
        }
    }
    return $names
}
function _WingetInstalledIds {
    $tmp = [IO.Path]::GetTempFileName()
    $ids = @{}
    try {
        & winget export -o $tmp --accept-source-agreements *> $null
        if (-not (Test-Path -LiteralPath $tmp)) { return $ids }
        $data = Get-Content -LiteralPath $tmp -Raw | ConvertFrom-Json -ErrorAction Stop
        foreach ($source in $data.Sources) {
            foreach ($pkg in $source.Packages) { $ids[$pkg.PackageIdentifier] = $true }
        }
    } catch { }
    finally { if (Test-Path -LiteralPath $tmp) { Remove-Item -LiteralPath $tmp -Force } }
    return $ids
}

_Heading 'scoop apps'
$scoopInstalled = _ScoopInstalledNames
$missingScoop = @($packages | Where-Object { $_.Kind -eq 'scoop' -and -not $scoopInstalled.ContainsKey($_.Name) })
if ($missingScoop.Count -gt 0) {
    _Arrow ('installing ' + $missingScoop.Count + ' scoop app(s)')
    foreach ($p in $missingScoop) { & scoop install $p.Name }
} else {
    _Arrow 'all scoop apps already installed'
}

$wingetEntries = @($packages | Where-Object { $_.Kind -eq 'winget' })
if ($wingetEntries.Count -gt 0) {
    _Heading 'winget apps'
    if (-not (Get-Command winget -ErrorAction SilentlyContinue)) {
        _Error 'winget not on PATH — declared winget entries skipped (install App Installer from the Microsoft Store)'
    } else {
        $wingetInstalled = _WingetInstalledIds
        $missingWinget   = @($wingetEntries | Where-Object { -not $wingetInstalled.ContainsKey($_.Name) })
        if ($missingWinget.Count -gt 0) {
            _Arrow ('installing ' + $missingWinget.Count + ' winget app(s)')
            foreach ($p in $missingWinget) {
                & winget install --id $p.Name --accept-package-agreements --accept-source-agreements
            }
        } else {
            _Arrow 'all winget apps already installed'
        }
    }
}
{{ end -}}
