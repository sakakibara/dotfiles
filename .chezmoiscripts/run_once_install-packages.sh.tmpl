{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
source {{ joinPath .chezmoi.sourceDir "etc" "bash" "lib" "init.bash" | quote }}

import unix darwin brew mise hive

main() {
  # Try to avoid having to type in the passwords over and over
  unix::keep_sudo

  # Check if command line tools is installed and try to install it if it isn't
  darwin::require_clt || exit 1

  # Brewfile hash: {{ include "etc/darwin/Brewfile" | sha256sum }}
  ask_to_run brew::setup

  ask_to_run mise::setup

  ask_to_run hive::setup
}

main "$@" || exit 1
{{ else if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
source {{ joinPath .chezmoi.sourceDir "etc" "bash" "lib" "init.bash" | quote }}

import unix linux mise extras hive

main() {
  unix::keep_sudo

  # Native packages via dnf/apt/pacman.
  # Fedora hash: {{ include "etc/linux/packages-fedora.txt" | sha256sum }}
  # Debian hash: {{ include "etc/linux/packages-debian.txt" | sha256sum }}
  # Arch hash:   {{ include "etc/linux/packages-arch.txt"   | sha256sum }}
  ask_to_run linux::setup

  ask_to_run mise::setup

  # Bucket-3 tools (starship, lazygit, lazydocker, gh, cargo-installed Rust
  # tools). Runs after mise so cargo is available via `mise exec`.
  ask_to_run extras::setup

  ask_to_run hive::setup
}

main "$@" || exit 1
{{ end -}}
