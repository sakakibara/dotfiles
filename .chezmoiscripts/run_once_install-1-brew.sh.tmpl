{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# Hash trigger — chezmoi re-runs this script whenever the comment hash below
# changes, which is whenever packages.txt or the blacklist changes.
# packages.txt hash: {{ include "etc/darwin/packages.txt" | sha256sum }}
# blacklist hash:    {{ include "etc/darwin/packages-blacklist.txt" | sha256sum }}
source {{ joinPath .chezmoi.sourceDir "etc" "bash" "lib" "init.bash" | quote }}

# Bake the profile into the env so brew::setup doesn't need to spawn chezmoi.
export DOTFILES_PROFILE={{ (index . "profile") | default "personal" | quote }}
export CHEZMOI_SOURCE_DIR={{ .chezmoi.sourceDir | quote }}

import unix darwin brew

unix::keep_sudo
darwin::require_clt || exit 1
brew::setup
{{ end -}}
