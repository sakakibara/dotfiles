#!/usr/bin/env bash
# Generate local, never-committed per-account git identity includes from the
# [[data.git_identities]] array in ~/.config/chezmoi/chezmoi.toml.
#
# This committed template holds only loop logic — every employer name, email,
# org pattern, and key lives in your LOCAL chezmoi config and in the generated
# ~/.config/git/*.inc files, neither of which is in this repo. So nothing here
# can leak into the public dotfiles repo.
#
# Each identity is selected by GitHub remote URL. Per-identity fields:
#   slug         required  filename-safe id (local only)
#   match_urls   required  list of remote.*.url globs that select this identity
#   email        required
#   name         optional  committer name override
#   signing_key  optional  sign this account's commits with this specific key
#   gpgsign      optional  set to false to NOT sign this account's commits
#   gh_account   optional  GitHub login; read by the mise GH_TOKEN env to pick
#                          this account for `gh` and HTTPS git in these repos
# Omit both signing_key and gpgsign to inherit the machine-default key and
# signing behaviour from ~/.gitconfig.
#
# ADDING AN ACCOUNT (end to end):
#   1. `gh auth login` as that account. REQUIRED for gh_account / HTTPS auth:
#      account-token runs `gh auth token --user <gh_account>`, which only works
#      if that account is logged into gh. Skip this and gh silently falls back
#      to the active account.
#   2. Add a [[data.git_identities]] entry here (local chezmoi.toml):
#      email + match_urls for commit identity; gh_account for auto-switch.
#   3. Signing (optional): make/find the key in 1Password, set signing_key
#      above, add its item to dot_config/1Password/ssh/agent.toml (op-ssh-sign
#      only signs with listed keys), and register the public key on GitHub as a
#      Signing Key. Or set `gpgsign = false` to not sign this account.
#   4. `chezmoi apply`, then `cd` into one of its repos to confirm identity,
#      signing (`git log --show-signature`), and `gh auth status`.
# The machine-default account (no [includeIf] match) is set once via
# gh_default_account in local chezmoi.toml; see dot_config/git/config.tmpl.
set -euo pipefail

gitdir="$HOME/.config/git"
mkdir -p "$gitdir"
# Always start clean so removing an identity from the array removes its files.
rm -f "$gitdir/identities.local.inc"
rm -f "$gitdir"/id-*.inc 2>/dev/null || true

{{- $ids := (index . "git_identities") | default (list) }}
{{- if $ids }}
cat > "$gitdir/identities.local.inc" <<'DISPATCH'
# Generated by chezmoi from [[data.git_identities]] in ~/.config/chezmoi/chezmoi.toml.
# Do not edit by hand — edit that array and run `chezmoi apply`.
{{- range $id := $ids }}
{{-   range $url := $id.match_urls }}
[includeIf "hasconfig:remote.*.url:{{ $url }}"]
	path = ~/.config/git/id-{{ $id.slug }}.inc
{{-   end }}
{{- end }}
DISPATCH
{{- range $id := $ids }}
cat > "$gitdir/id-{{ $id.slug }}.inc" <<'LEAF'
[user]
	email = {{ $id.email }}
{{- if (index $id "name") }}
	name = {{ $id.name }}
{{- end }}
{{- if (index $id "signing_key") }}
	signingkey = {{ $id.signing_key }}
{{- end }}
{{- if (index $id "gh_account") }}
[github]
	account = {{ $id.gh_account }}
{{- end }}
{{- if and (hasKey $id "gpgsign") (not (index $id "gpgsign")) }}
[commit]
	gpgsign = false
[tag]
	gpgsign = false
{{- end }}
LEAF
{{- end }}
{{- end }}
