{{ if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash
# Hash trigger — re-runs when the hive config or the hive library changes.
# hive config hash: {{ include "dot_config/hive/config.toml.tmpl" | sha256sum }}
# hive.bash hash:   {{ include "etc/bash/lib/hive.bash"          | sha256sum }}
source {{ joinPath .chezmoi.sourceDir "etc" "bash" "lib" "init.bash" | quote }}

import unix hive

unix::keep_sudo
hive::setup
{{ end -}}
