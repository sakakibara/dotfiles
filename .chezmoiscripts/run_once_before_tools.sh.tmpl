{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# Hash trigger — re-runs when the tools installer logic changes
# (starship, lazygit, lazydocker, gh, cargo-installed Rust tools). Runs
# after mise so `mise exec cargo` is on PATH.
# tools.bash hash: {{ include "etc/bash/lib/tools.bash" | sha256sum }}
source {{ joinPath .chezmoi.sourceDir "etc" "bash" "lib" "init.bash" | quote }}

import unix tools

unix::keep_sudo
tools::setup
{{ end -}}
