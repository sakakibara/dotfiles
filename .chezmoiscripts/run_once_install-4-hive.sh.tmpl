{{ if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash
# Hash trigger — re-runs when the hive workspace config template changes.
# hive config hash: {{ include "dot_config/hive/config.toml.tmpl" | sha256sum }}
source {{ joinPath .chezmoi.sourceDir "etc" "bash" "lib" "init.bash" | quote }}

import unix hive

unix::keep_sudo
hive::setup
{{ end -}}
