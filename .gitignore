Brewfile.lock.json
flycheck_*

# Belt-and-suspenders: never commit anything under src/.ssh/ except the
# config template. Even if a gate would prevent application, we don't want
# raw key material reaching the repo at all.
src/.ssh/*
!src/.ssh/config

# The global git ignore excludes .claude/ (live Claude state). mox's source
# tree uses native names, so src/.claude/ is the managed CONFIG source, not
# live state -- re-include it. Secrets stay out of src/ via .moxignore.
!src/.claude/
