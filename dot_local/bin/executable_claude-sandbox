#!/usr/bin/env bash
# claude-sandbox — Docker-isolated Claude Code, one container per repo.
#
# Default behaviour: in a repo, `claude-sandbox` starts a container with
# `claude --remote-control --dangerously-skip-permissions` inside and
# attaches an interactive TTY. Detach with Ctrl-p Ctrl-q to leave the
# container running so you can drive the same session from claude.ai/code
# or the Claude mobile app — `--remote-control` polls the Anthropic API
# outbound, no inbound port is opened.
#
# Subcommands:
#   claude-sandbox [--auto|--bypass] [repo]   start + attach (default; bypass)
#   claude-sandbox start [--auto] [repo]      start detached (no TTY)
#   claude-sandbox attach [name]              attach to a running sandbox
#   claude-sandbox stop [name|--all]          stop & remove
#   claude-sandbox list                       all sandboxes (running + stopped)
#   claude-sandbox info                       image + sandbox status
#   claude-sandbox rebuild                    docker build --no-cache
#   claude-sandbox enable-autostart [repo]    LaunchAgent: start at login
#   claude-sandbox disable-autostart [repo]
#   claude-sandbox help

set -euo pipefail

# ANSI color helpers — only when stdout is a TTY (matches the dotfiles
# wrapper's pattern).
if [[ -t 1 ]]; then
  C_DIM=$'\033[2m'
  C_BOLD=$'\033[1m'
  C_RED=$'\033[31m'
  C_YELLOW=$'\033[33m'
  C_RESET=$'\033[0m'
else
  C_DIM=""; C_BOLD=""; C_RED=""; C_YELLOW=""; C_RESET=""
fi

_die()  { printf '%sclaude-sandbox: %s%s\n' "$C_RED" "$*" "$C_RESET" >&2; exit 1; }
_warn() { printf '%sclaude-sandbox: %s%s\n' "$C_YELLOW" "$*" "$C_RESET" >&2; }
_info() { printf '%sclaude-sandbox:%s %s\n' "$C_DIM" "$C_RESET" "$*"; }
_row()  { printf '%s%-7s%s %s\n' "$C_BOLD" "$1" "$C_RESET" "$2"; }

IMAGE="claude-sandbox:latest"
NAME_PREFIX="claude-sandbox"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/claude-sandbox"

_require_docker() {
  command -v docker >/dev/null 2>&1 \
    || _die "docker not found on PATH (install OrbStack via brew)"
  docker info >/dev/null 2>&1 \
    || _die "docker daemon unreachable (is OrbStack running?)"
}

_chezmoi_source() {
  command -v chezmoi >/dev/null 2>&1 || _die "chezmoi not found on PATH"
  chezmoi source-path 2>/dev/null || _die "could not resolve chezmoi source"
}

_dockerfile_dir() { printf '%s/etc/sandbox\n' "$(_chezmoi_source)"; }

# Hash of Dockerfile + entrypoint — used to detect when a rebuild is needed.
_dockerfile_hash() {
  local dir; dir=$(_dockerfile_dir)
  [[ -f "$dir/Dockerfile" ]]   || _die "Dockerfile not found at $dir/Dockerfile"
  [[ -f "$dir/entrypoint.sh" ]] || _die "entrypoint.sh not found at $dir/entrypoint.sh"
  cat "$dir/Dockerfile" "$dir/entrypoint.sh" | shasum -a 256 | cut -d' ' -f1
}

_built_hash_file() { printf '%s/built-hash\n' "$CACHE_DIR"; }
_image_built()     { docker image inspect "$IMAGE" >/dev/null 2>&1; }

# Container name policy:
#   <base> = sanitized repo basename
#   suffix order: [-mode][-name | -N]
#   - mode suffix:  "-wt" for --worktree, "-strict" for --strict, none for default
#   - name suffix:  "-<sanitized-X>" when user passes --name X (named slot)
#   - integer N:    auto-bumped suffix when the user runs `csb new` for
#                   parallel sessions, OR when cross-repo basename collision
#                   forces a different name. N starts at 2 (first session
#                   has no suffix).
# No path hash anywhere user-visible. Cross-repo collision is detected
# via the claude-sandbox.workspace label set at create time, then the
# wrapper auto-bumps to the next free integer suffix.
_container_name_base() {
  local repo="$1" mode="${2:-default}" name_override="${3:-}"
  local base; base=$(basename "$(cd "$repo" && pwd -P)" | tr -c 'A-Za-z0-9_.-' '_')
  local mode_suffix="" name_suffix=""
  case "$mode" in
    worktree) mode_suffix="-wt" ;;
    strict)   mode_suffix="-strict" ;;
  esac
  if [[ -n "$name_override" ]]; then
    name_suffix="-$(printf '%s' "$name_override" | tr -c 'A-Za-z0-9_.-' '_')"
  fi
  printf '%s-%s%s%s\n' "$NAME_PREFIX" "$base" "$mode_suffix" "$name_suffix"
}

# Backwards-compatible alias used by older code paths that still want
# "the canonical first name without auto-numbering" (volume helpers etc.).
_container_name() { _container_name_base "$@"; }

# Read a container's claude-sandbox.workspace label. Empty for legacy
# (pre-label) containers; treat empty as a wildcard match.
_container_workspace_label() {
  docker container inspect -f '{{ index .Config.Labels "claude-sandbox.workspace" }}' "$1" 2>/dev/null
}

# Containers belonging to (repo, mode, name_override) — i.e., name matches
# the canonical base optionally followed by `-<integer>`, AND the workspace
# label matches (or is absent / matches as wildcard for legacy).
# When name_override is set, the match is exact (named slots don't auto-number).
_containers_for_target() {
  local repo="$1" mode="${2:-default}" name_override="${3:-}"
  local base; base=$(_container_name_base "$repo" "$mode" "$name_override")
  local pattern
  if [[ -n "$name_override" ]]; then
    pattern="^${base}\$"
  else
    pattern="^${base}(-[0-9]+)?\$"
  fi
  while IFS= read -r name; do
    [[ -z "$name" ]] && continue
    [[ "$name" =~ $pattern ]] || continue
    local ws; ws=$(_container_workspace_label "$name")
    [[ -z "$ws" || "$ws" == "$repo" ]] && printf '%s\n' "$name"
  done < <(docker ps -a --filter "name=^${NAME_PREFIX}-" --format '{{.Names}}' 2>/dev/null)
}

# First container name in the canonical sequence (base, base-2, base-3, …)
# that is either free (doesn't exist) or owned by us (workspace label
# matches). Skips names taken by OTHER repos. Used for both auto-bump on
# create and locating "where the next parallel session would land."
_next_free_name() {
  local repo="$1" mode="$2" name_override="$3"
  local base; base=$(_container_name_base "$repo" "$mode" "$name_override")
  local n=1 candidate="$base"
  while true; do
    if ! _container_exists "$candidate"; then
      printf '%s\n' "$candidate"; return
    fi
    local ws; ws=$(_container_workspace_label "$candidate")
    # Belongs to us OR is a legacy (no label) container we'll claim.
    if [[ -z "$ws" || "$ws" == "$repo" ]]; then
      printf '%s\n' "$candidate"; return
    fi
    n=$((n + 1)); candidate="${base}-${n}"
  done
}

# Resolve the target container name + action ("attach" or "create") for
# (repo, mode, name_override, force_new). Outputs "<name>\t<action>" on
# stdout, or exits via _die / interactive picker dismissal.
_resolve_target() {
  local repo="$1" mode="$2" name_override="$3" force_new="${4:-}"
  local base; base=$(_container_name_base "$repo" "$mode" "$name_override")

  # Named slot semantics: exact match or create. Cross-repo collision on
  # the same name → fail with a helpful hint.
  if [[ -n "$name_override" ]]; then
    if _container_exists "$base"; then
      local ws; ws=$(_container_workspace_label "$base")
      if [[ -z "$ws" || "$ws" == "$repo" ]]; then
        printf '%s\tattach\n' "$base"; return
      fi
      _die "name '$name_override' is already used by another repo: $ws
       use a different --name to disambiguate"
    fi
    printf '%s\tcreate\n' "$base"; return
  fi

  # Force-create: auto-bump to next free integer.
  if [[ -n "$force_new" ]]; then
    local target; target=$(_next_free_name "$repo" "$mode" "")
    # _next_free_name returns first free OR ours; force_new wants a NEW one,
    # so if it returned an existing-ours, bump beyond it.
    if _container_exists "$target"; then
      local n=2
      while _container_exists "${base}-${n}"; do n=$((n + 1)); done
      target="${base}-${n}"
    fi
    printf '%s\tcreate\n' "$target"; return
  fi

  # Smart default: existing for this repo+mode? attach (single) or pick
  # (multi). None? create at first free name.
  local matches; matches=$(_containers_for_target "$repo" "$mode" "")
  if [[ -z "$matches" ]]; then
    local target; target=$(_next_free_name "$repo" "$mode" "")
    printf '%s\tcreate\n' "$target"; return
  fi
  local count; count=$(printf '%s\n' "$matches" | grep -c .)
  if (( count == 1 )); then
    printf '%s\tattach\n' "$matches"; return
  fi
  command -v fzf >/dev/null 2>&1 \
    || _die "$count sandboxes for this repo+mode; install fzf or pass --name"
  local picked; picked=$(printf '%s\n' "$matches" \
    | fzf --height 40% --reverse --prompt 'sandbox> ' --no-info)
  [[ -z "$picked" ]] && exit 0
  printf '%s\tattach\n' "$picked"
}

# Worktree path: filesystem path needs to be unique per host repo, so we
# keep an 8-char hash here (it never appears in container names or iOS
# labels — purely a filesystem-uniqueness concern under cache dir).
_worktree_path() {
  local repo="$1"
  local abs base hash
  abs=$(cd "$repo" && pwd -P)
  base=$(basename "$abs" | tr -c 'A-Za-z0-9_.-' '_')
  hash=$(printf '%s' "$abs" | shasum -a 256 | cut -c1-8)
  printf '%s/worktrees/%s-%s\n' "$CACHE_DIR" "$base" "$hash"
}

# Worktree branch name: lives in the host repo's git db, so it only
# needs to be unique within that one repo. No cross-repo hash needed.
_worktree_branch() {
  local repo="$1"
  local base; base=$(basename "$(cd "$repo" && pwd -P)" | tr -c 'A-Za-z0-9_.-' '_')
  printf 'claude-sandbox/%s\n' "$base"
}

# Strict-mode volume names. Derived from the container name so they
# track the same disambiguation scheme (--name suffix, etc.). The
# workspace volume's host-repo label is checked at seed time for
# cross-repo collision (see _ensure_strict_volumes).
_strict_ws_volume() {
  local repo="$1" name_override="${2:-}"
  printf '%s-ws\n' "$(_container_name "$repo" strict "$name_override")"
}
_strict_cl_volume() {
  local repo="$1" name_override="${2:-}"
  printf '%s-cl\n' "$(_container_name "$repo" strict "$name_override")"
}

_container_exists()  { docker container inspect "$1" >/dev/null 2>&1; }
_container_running() {
  [[ "$(docker container inspect -f '{{.State.Running}}' "$1" 2>/dev/null)" == "true" ]]
}

# True when the container was created from an older image than the
# current $IMAGE. Bind-mount specs are baked in at create time, so a
# stale container won't pick up new -v args after a rebuild — `start`
# would resurrect it with old mounts. Detecting this lets us remove +
# recreate cleanly.
_container_stale() {
  local name="$1"
  local container_image current_image
  container_image=$(docker container inspect -f '{{.Image}}' "$name" 2>/dev/null) || return 1
  current_image=$(docker image inspect -f '{{.Id}}' "$IMAGE" 2>/dev/null) || return 1
  [[ "$container_image" != "$current_image" ]]
}

# Resolve the target repo: explicit arg if given, else git toplevel of
# cwd, else cwd. Returns absolute path.
_resolve_repo() {
  local arg="${1:-}"
  if [[ -n "$arg" ]]; then
    [[ -d "$arg" ]] || _die "no such directory: $arg"
    (cd "$arg" && pwd -P)
    return
  fi
  local top
  if top=$(git rev-parse --show-toplevel 2>/dev/null); then
    printf '%s\n' "$top"
  else
    pwd -P
  fi
}

# Visible cues that this terminal is inside a sandbox. starship's
# [custom.sandbox] indicator only renders in shell prompts — but
# claude-sandbox drops straight into Claude's UI, no shell visible.
# A printed banner is wiped by Claude's first redraw; the terminal
# title (OSC 0) survives because Claude doesn't manage it.
_print_banner() {
  local name="$1" repo="$2" label="${3:-}" perm="${4:-?}" iso="${5:-?}"
  if [[ -t 1 ]]; then
    # OSC 0: terminal title + icon name. Persists across Claude's
    # redraws because Claude doesn't manage the title bar.
    if [[ -n "$label" ]]; then
      printf '\033]0;%s\007' "$label"
    else
      printf '\033]0;🛡 claude-sandbox · %s\007' "$name"
    fi
  fi
  printf '%s━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━%s\n' "$C_DIM" "$C_RESET"
  printf '%s🛡  claude-sandbox%s · %s\n' "$C_BOLD" "$C_RESET" "$name"
  printf '   workspace: %s\n' "$repo"
  [[ -n "$label" ]] && printf '   ios label: %s\n' "$label"
  if [[ "$perm" != "?" || "$iso" != "?" ]]; then
    printf '   mode:      perm=%s iso=%s\n' "$perm" "$iso"
  fi
  printf '   detach:    Ctrl-p Ctrl-q (container keeps running)\n'
  printf '%s━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━%s\n' "$C_DIM" "$C_RESET"
}

# Claude CLI args. The label (when given) is passed via `claude --name`
# so the iOS app shows a stable, distinguishable session label instead
# of the auto-derived first-prompt-summary that drifts over time.
_claude_args() {
  local perm="$1" label="${2:-}"
  local args=( --remote-control )
  [[ -n "$label" ]] && args+=( --name "$label" )
  case "$perm" in
    auto)   args+=( --permission-mode acceptEdits ) ;;
    bypass) args+=( --dangerously-skip-permissions ) ;;
    *)      _die "unknown permission mode: $perm" ;;
  esac
  printf '%s\n' "${args[@]}"
}

# iOS-app-visible label. Prefix with 🛡 so sandbox sessions are
# instantly distinguishable from non-sandbox ones in the session list.
_session_label_for() {
  local container_name="$1" name_override="${2:-}"
  if [[ -n "$name_override" ]]; then
    printf '🛡 %s\n' "$name_override"
    return
  fi
  # Strip the wrapper prefix so the label is just `<base>[-mode][-N]`.
  local short="${container_name#${NAME_PREFIX}-}"
  printf '🛡 %s\n' "$short"
}

# Build the docker run mount/env arg list for a given mode.
#
# default:  bind-mount the repo at its host path inside the container.
#           Mirroring the path matters because Claude's per-project
#           session memory is keyed at ~/.claude/projects/<path>/ — if
#           we mounted at /workspace the in-sandbox memory would split
#           into a separate dir from the host's. Mirroring keeps memory
#           continuous between sandbox and non-sandbox sessions.
# worktree: the git worktree is mounted at the *host repo's* path so
#           memory keys to the project, not the throwaway worktree.
# strict:   the workspace volume is also mounted at the host repo's
#           path — the volume's contents diverge from host but the path
#           encoding stays consistent inside the container.
_run_args() {
  local repo="$1" name="$2" mode="${3:-default}"
  local args=(
    --name     "$name"
    --hostname "$name"
    --label    "claude-sandbox.workspace=$repo"
    --label    "claude-sandbox.iso=$mode"
    -e CLAUDE_SANDBOX=1
    -v "$HOME/.gitconfig":/home/claude/.gitconfig:ro
    -w "$repo"
  )

  # Bind-mount $HOME/.claude.json (the live config file separate from
  # the .claude/ directory) for default + worktree. Touch it first if
  # missing so docker doesn't auto-create a directory at the bind path.
  # For strict mode, the file is seeded into the cl_volume during
  # _ensure_strict_volumes; the entrypoint symlinks it into place so
  # writes persist in the volume.
  if [[ "$mode" != "strict" ]]; then
    [[ -e "$HOME/.claude.json" ]] || touch "$HOME/.claude.json"
    args+=( -v "$HOME/.claude.json":/home/claude/.claude.json )
  fi

  case "$mode" in
    default)
      args+=( -v "$repo":"$repo"
              -v "$HOME/.claude":/home/claude/.claude )
      ;;
    worktree)
      local wt; wt=$(_worktree_path "$repo")
      args+=( -v "$wt":"$repo"
              -v "$HOME/.claude":/home/claude/.claude )
      ;;
    strict)
      args+=( -v "$(_strict_ws_volume "$repo" "${NAME_OVERRIDE:-}")":"$repo"
              -v "$(_strict_cl_volume "$repo" "${NAME_OVERRIDE:-}")":/home/claude/.claude )
      ;;
    *) _die "unknown isolation mode: $mode" ;;
  esac
  printf '%s\n' "${args[@]}"
}

# --worktree: create a fresh git worktree on a throwaway branch so
# Claude works in a checkout that's disjoint from the user's main one.
_ensure_worktree() {
  local repo="$1"
  [[ -d "$repo/.git" || -f "$repo/.git" ]] || _die "$repo is not a git repo (--worktree requires git)"
  local wt branch
  wt=$(_worktree_path "$repo")
  branch=$(_worktree_branch "$repo")
  if [[ -d "$wt" ]]; then return 0; fi
  mkdir -p "$(dirname "$wt")"
  # If the branch already exists (from a prior worktree that was rm'd
  # without `git worktree remove`), reuse it instead of erroring.
  if git -C "$repo" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$repo" worktree add "$wt" "$branch"
  else
    git -C "$repo" worktree add -b "$branch" "$wt"
  fi
  _info "worktree: $wt (branch $branch)"
}

# --strict: ensure both volumes exist and are seeded. Seeding only
# happens once (when the volume is first created); subsequent starts
# reuse the volume so Claude's in-progress work survives container
# recreation.
_ensure_strict_volumes() {
  local repo="$1" name_override="${2:-}"
  local ws cl
  ws=$(_strict_ws_volume "$repo" "$name_override")
  cl=$(_strict_cl_volume "$repo" "$name_override")

  if ! docker volume inspect "$ws" >/dev/null 2>&1; then
    _info "creating + seeding $ws from $repo"
    docker volume create \
      --label "claude-sandbox.host-repo=${repo}" \
      --label "claude-sandbox.kind=workspace" \
      "$ws" >/dev/null
    docker run --rm \
      -v "$repo":/src:ro \
      -v "$ws":/dst \
      "$IMAGE" \
      sh -c 'cp -a /src/. /dst/' >/dev/null
  fi

  if ! docker volume inspect "$cl" >/dev/null 2>&1; then
    _info "creating $cl"
    docker volume create \
      --label "claude-sandbox.kind=claude-home" \
      "$cl" >/dev/null
    if [[ -d "$HOME/.claude" ]]; then
      _info "seeding $cl from ~/.claude (one time only)"
      docker run --rm \
        -v "$HOME/.claude":/src:ro \
        -v "$cl":/dst \
        "$IMAGE" \
        sh -c 'cp -a /src/. /dst/' >/dev/null
    fi
    # Also seed ~/.claude.json into the volume root as `.csb-claude.json`.
    # The entrypoint symlinks `$HOME/.claude.json` to it so reads/writes
    # by claude inside the sandbox persist in the volume rather than
    # bouncing off the ephemeral image filesystem.
    if [[ -f "$HOME/.claude.json" ]]; then
      _info "seeding $cl with ~/.claude.json (as .csb-claude.json)"
      docker run --rm \
        -v "$HOME":/host:ro \
        -v "$cl":/dst \
        "$IMAGE" \
        sh -c 'cp /host/.claude.json /dst/.csb-claude.json' >/dev/null
    fi
  fi
}

_ensure_image() {
  mkdir -p "$CACHE_DIR"
  local current built
  current=$(_dockerfile_hash)
  built=$(cat "$(_built_hash_file)" 2>/dev/null || echo "")

  if ! _image_built; then
    _info "image $IMAGE not built yet — building"
    _build_image
    return
  fi

  if [[ "$current" != "$built" ]]; then
    _warn "image inputs (Dockerfile or entrypoint.sh) changed since last build."
    if [[ -t 0 ]]; then
      printf 'Rebuild now? [Y/n] '
      local ans; read -r ans
      if [[ -z "$ans" || "$ans" =~ ^[Yy] ]]; then
        _build_image
      else
        _info "skipping rebuild; using stale image"
      fi
    else
      _info "non-interactive; skipping rebuild"
    fi
  fi
}

_build_image() {
  local dir; dir=$(_dockerfile_dir)
  _info "docker build -t $IMAGE $dir"
  docker build -t "$IMAGE" "$dir"
  _dockerfile_hash > "$(_built_hash_file)"
}

# ── subcommands ────────────────────────────────────────────────────────

# Parse common flags: permission mode + isolation mode. Sets the
# globals PERM_MODE and ISO_MODE; consumed positional args are shifted
# off via the caller. Stops at the first non-flag argument.
_parse_common_flags() {
  PERM_MODE="bypass"
  ISO_MODE="default"
  NAME_OVERRIDE=""
  while (($#)); do
    case "$1" in
      --auto)     PERM_MODE="auto";   shift ;;
      --bypass)   PERM_MODE="bypass"; shift ;;
      --worktree) ISO_MODE="worktree"; shift ;;
      --strict)   ISO_MODE="strict";  shift ;;
      --name)     NAME_OVERRIDE="${2:-}"; [[ -z "$NAME_OVERRIDE" ]] && _die "--name requires an argument"; shift 2 ;;
      --name=*)   NAME_OVERRIDE="${1#--name=}"; shift ;;
      --) shift; break ;;
      -*) _die "unknown option: $1" ;;
      *)  break ;;
    esac
  done
  REMAINING=( "$@" )
}

# cmd_default — smart attach-or-create.
#
# Resolves a target via _resolve_target (which knows about cwd repo,
# mode, --name, and existing containers): zero existing → create at
# next free name; one existing → attach; multiple → fzf picker.
# `force_new` is empty here; cmd_new flips it.
cmd_default() {
  local force_new="${FORCE_NEW:-}"
  _parse_common_flags "$@"
  local repo; repo=$(_resolve_repo "${REMAINING[0]:-}")
  _require_docker
  _ensure_image

  case "$ISO_MODE" in
    worktree) _ensure_worktree "$repo" ;;
    strict)   _ensure_strict_volumes "$repo" "$NAME_OVERRIDE" ;;
  esac

  local resolved name action
  resolved=$(_resolve_target "$repo" "$ISO_MODE" "$NAME_OVERRIDE" "$force_new")
  name=${resolved%%$'\t'*}
  action=${resolved##*$'\t'}

  # Stale container (older image): remove so we create fresh with new mounts.
  if [[ "$action" == "attach" ]] && _container_stale "$name"; then
    _info "container $name was built from an older image; recreating"
    docker rm -f "$name" >/dev/null
    action="create"
  fi

  local label; label=$(_session_label_for "$name" "$NAME_OVERRIDE")

  if [[ "$action" == "attach" ]]; then
    if _container_running "$name"; then
      _print_banner "$name" "$repo" "$label"
      exec docker attach "$name"
    fi
    _info "starting stopped $name"
    docker start "$name" >/dev/null
    _print_banner "$name" "$repo" "$label"
    exec docker attach "$name"
  fi

  _info "creating $name (perm=$PERM_MODE iso=$ISO_MODE)"
  local run_args=() c_args=()
  mapfile -t run_args < <(_run_args "$repo" "$name" "$ISO_MODE")
  mapfile -t c_args   < <(_claude_args "$PERM_MODE" "$label")
  _print_banner "$name" "$repo" "$label" "$PERM_MODE" "$ISO_MODE"
  exec docker run -it "${run_args[@]}" "$IMAGE" claude "${c_args[@]}"
}

# cmd_new — force-create a parallel session, never attach to existing.
cmd_new() { FORCE_NEW=1 cmd_default "$@"; }

cmd_start() {
  _parse_common_flags "$@"
  local repo; repo=$(_resolve_repo "${REMAINING[0]:-}")
  _require_docker
  _ensure_image

  case "$ISO_MODE" in
    worktree) _ensure_worktree "$repo" ;;
    strict)   _ensure_strict_volumes "$repo" "$NAME_OVERRIDE" ;;
  esac

  local resolved name action
  resolved=$(_resolve_target "$repo" "$ISO_MODE" "$NAME_OVERRIDE" "")
  name=${resolved%%$'\t'*}
  action=${resolved##*$'\t'}

  if [[ "$action" == "attach" ]] && _container_stale "$name"; then
    _info "container $name was built from an older image; recreating"
    docker rm -f "$name" >/dev/null
    action="create"
  fi

  if [[ "$action" == "attach" ]]; then
    if _container_running "$name"; then _info "$name already running"; return 0; fi
    _info "starting stopped $name"
    docker start "$name" >/dev/null
    return 0
  fi

  local label; label=$(_session_label_for "$name" "$NAME_OVERRIDE")
  _info "creating detached $name (perm=$PERM_MODE iso=$ISO_MODE)"
  local run_args=() c_args=()
  mapfile -t run_args < <(_run_args "$repo" "$name" "$ISO_MODE")
  mapfile -t c_args   < <(_claude_args "$PERM_MODE" "$label")
  docker run -d "${run_args[@]}" "$IMAGE" claude "${c_args[@]}" >/dev/null
  _info "started $name"
}

cmd_attach() {
  _require_docker
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    name=$(_pick_running) || return 0
  fi
  _container_running "$name" || _die "$name not running"
  local repo
  repo=$(_container_workspace_label "$name")
  [[ -z "$repo" ]] && repo="(unknown)"
  local label; label=$(_session_label_for "$name")
  _print_banner "$name" "$repo" "$label"
  exec docker attach "$name"
}

# fzf-driven picker over running sandboxes (mirrors the `tm` helper).
_pick_running() {
  local list; list=$(docker ps --filter "name=^${NAME_PREFIX}-" --format '{{.Names}}')
  if [[ -z "$list" ]]; then
    _info "no running sandboxes"
    return 1
  fi
  if [[ $(printf '%s\n' "$list" | wc -l | tr -d ' ') == "1" ]]; then
    printf '%s' "$list"
    return 0
  fi
  command -v fzf >/dev/null 2>&1 \
    || _die "multiple running sandboxes; install fzf or pass a name"
  printf '%s\n' "$list" | fzf --height 40% --reverse --prompt 'sandbox> '
}

cmd_stop() {
  _require_docker
  local purge=0 scope="" arg=""
  while (($#)); do
    case "$1" in
      --purge)     purge=1; shift ;;
      --all)       scope="all"; shift ;;
      --all-here)  scope="here"; shift ;;
      *)           arg="$1"; shift; break ;;
    esac
  done

  if [[ "$scope" == "all" ]]; then
    local containers; containers=$(docker ps -aq --filter "name=^${NAME_PREFIX}-")
    if [[ -z "$containers" ]]; then _info "no sandboxes to stop"; return 0; fi
    docker rm -f $containers >/dev/null
    _info "stopped all sandboxes"
    return 0
  fi

  if [[ "$scope" == "here" ]]; then
    local repo; repo=$(_resolve_repo)
    local matches; matches=$(_containers_for_target "$repo" "default" ""; \
                              _containers_for_target "$repo" "worktree" ""; \
                              _containers_for_target "$repo" "strict" "")
    [[ -z "$matches" ]] && { _info "no sandboxes for $repo"; return 0; }
    while IFS= read -r n; do
      [[ -z "$n" ]] && continue
      docker rm -f "$n" >/dev/null && _info "stopped $n"
    done <<< "$matches"
    return 0
  fi

  # No scope: explicit name OR pick from cwd's sandboxes.
  local name="$arg" repo=""
  if [[ -z "$name" ]]; then
    repo=$(_resolve_repo)
    local matches; matches=$(_containers_for_target "$repo" "default" ""; \
                              _containers_for_target "$repo" "worktree" ""; \
                              _containers_for_target "$repo" "strict" "")
    [[ -z "$matches" ]] && _die "no sandbox for $repo"
    local count; count=$(printf '%s\n' "$matches" | grep -c .)
    if (( count == 1 )); then
      name="$matches"
    else
      command -v fzf >/dev/null 2>&1 \
        || _die "$count sandboxes here; pick one: $(printf '%s\n' "$matches" | tr '\n' ' ')"
      name=$(printf '%s\n' "$matches" \
        | fzf --height 40% --reverse --prompt 'stop> ' --no-info)
      [[ -z "$name" ]] && exit 0
    fi
  fi

  _container_exists "$name" || _die "$name does not exist"
  [[ -z "$repo" ]] && repo=$(_container_workspace_label "$name")
  docker rm -f "$name" >/dev/null
  _info "stopped $name"

  # Purge: remove the worktree and/or strict volumes too. Without
  # --purge, those persist so a later `claude-sandbox` reattaches to
  # the same state (--strict's whole point) or the same worktree.
  if (( purge )); then
    case "$name" in
      *-wt)
        # Recover the original repo from worktree metadata.
        if [[ -z "$repo" ]]; then
          # Best effort: ask the user to pass the path; we don't store it.
          _warn "purge: pass the repo path via 'claude-sandbox stop --purge <name>' from inside the repo"
        else
          local wt; wt=$(_worktree_path "$repo")
          if [[ -d "$wt" ]]; then
            git -C "$repo" worktree remove --force "$wt" 2>/dev/null \
              || rm -rf "$wt"
            _info "removed worktree $wt"
          fi
        fi
        ;;
      *-strict)
        local ws cl
        if [[ -n "$repo" ]]; then
          ws=$(_strict_ws_volume "$repo")
          cl=$(_strict_cl_volume "$repo")
        else
          # Reverse-engineer volume names from the container name suffix.
          ws="${name}-ws"
          cl="${name}-cl"
        fi
        docker volume rm "$ws" "$cl" 2>/dev/null || true
        _info "removed volumes $ws $cl"
        ;;
    esac
  fi
}

# --strict export: git-fetch the volume's branches into the host repo
# under refs/sandbox-export/* so the user can review and merge at their
# own pace. Only committed history transfers; uncommitted working-tree
# changes do not (commit them first inside the sandbox).
cmd_export() {
  _require_docker
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    local repo; repo=$(_resolve_repo)
    local matches; matches=$(_containers_for_target "$repo" "strict" "")
    [[ -z "$matches" ]] && _die "no --strict sandbox for $repo"
    local count; count=$(printf '%s\n' "$matches" | grep -c .)
    if (( count == 1 )); then
      name="$matches"
    else
      command -v fzf >/dev/null 2>&1 \
        || _die "$count strict sandboxes here; pass one explicitly"
      name=$(printf '%s\n' "$matches" \
        | fzf --height 40% --reverse --prompt 'export> ' --no-info)
      [[ -z "$name" ]] && exit 0
    fi
  fi
  case "$name" in
    *-strict|*-strict-[0-9]*|*-strict-*) ;;
    *) _die "export only applies to --strict sandboxes; '$name' is not one" ;;
  esac
  local ws="${name}-ws"
  docker volume inspect "$ws" >/dev/null 2>&1 || _die "volume $ws not found"

  local host_repo
  host_repo=$(docker volume inspect "$ws" -f '{{ index .Labels "claude-sandbox.host-repo" }}' 2>/dev/null)
  [[ -n "$host_repo" && -d "$host_repo/.git" ]] \
    || _die "could not resolve host repo from $ws label, or repo is not a git repo"

  if _container_running "$name"; then
    _warn "container $name is running; export reflects only committed history"
  fi

  _info "fetching from $ws into $host_repo as refs/sandbox-export/*"
  docker run --rm \
    -v "$host_repo":/host \
    -v "$ws":/sandbox:ro \
    "$IMAGE" \
    git -C /host fetch /sandbox 'refs/heads/*:refs/sandbox-export/*' --tags --force --no-write-fetch-head

  _info "review:  git -C $host_repo for-each-ref refs/sandbox-export/"
  _info "diff:    git -C $host_repo diff <branch>..refs/sandbox-export/<branch>"
  _info "merge:   git -C $host_repo merge refs/sandbox-export/<branch>"
  _info "drop:    git -C $host_repo for-each-ref --format='delete %(refname)' refs/sandbox-export/ | git -C $host_repo update-ref --stdin"
}

cmd_list() {
  _require_docker
  local out
  out=$(docker ps -a --filter "name=^${NAME_PREFIX}-" \
    --format '{{.Names}}\t{{.Status}}\t{{.Label "claude-sandbox.workspace"}}')
  if [[ -z "$out" ]]; then _info "no sandboxes"; return 0; fi
  printf '%s%-40s %-25s %s%s\n' "$C_BOLD" NAME STATUS WORKSPACE "$C_RESET"
  printf '%s\n' "$out" | column -t -s $'\t'
}

cmd_info() {
  _row "Image:"  "$IMAGE"
  if _image_built; then
    local id; id=$(docker image inspect -f '{{.Id}}' "$IMAGE" 2>/dev/null | cut -c8-19)
    _row "Built:" "$id"
  else
    _row "Built:" "${C_YELLOW}not built${C_RESET}"
  fi
  local current stored
  current=$(_dockerfile_hash 2>/dev/null || echo "?")
  stored=$(cat "$(_built_hash_file)" 2>/dev/null || echo "?")
  if [[ "$current" == "$stored" ]]; then
    _row "Hash:"  "$current"
  else
    _row "Hash:"  "${C_YELLOW}$current (current) ≠ $stored (built)${C_RESET}"
  fi
  _row "Cache:" "$CACHE_DIR"
  echo
  cmd_list
}

cmd_rebuild() {
  _require_docker
  local dir; dir=$(_dockerfile_dir)
  _info "docker build --no-cache -t $IMAGE $dir"
  docker build --no-cache -t "$IMAGE" "$dir"
  _dockerfile_hash > "$(_built_hash_file)"
}

# LaunchAgent path: per-repo, keyed by an 8-char path hash so multiple
# repos can be autostarted independently.
_plist_path() {
  local repo="$1"
  local hash; hash=$(printf '%s' "$repo" | shasum -a 256 | cut -c1-8)
  printf '%s/Library/LaunchAgents/dev.sakakibara.claude-sandbox.%s.plist\n' "$HOME" "$hash"
}

cmd_enable_autostart() {
  local repo plist self
  repo=$(_resolve_repo "${1:-}")
  plist=$(_plist_path "$repo")
  self=$(command -v claude-sandbox) || _die "claude-sandbox not on PATH"
  mkdir -p "$(dirname "$plist")" "$CACHE_DIR"

  cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$(basename "$plist" .plist)</string>
  <key>ProgramArguments</key>
  <array>
    <string>$self</string>
    <string>start</string>
    <string>$repo</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$CACHE_DIR/autostart.log</string>
  <key>StandardErrorPath</key>
  <string>$CACHE_DIR/autostart.log</string>
</dict>
</plist>
EOF
  launchctl load "$plist" 2>/dev/null || true
  _info "autostart enabled for $repo"
  _info "plist: $plist"
}

cmd_disable_autostart() {
  local repo plist
  repo=$(_resolve_repo "${1:-}")
  plist=$(_plist_path "$repo")
  if [[ -f "$plist" ]]; then
    launchctl unload "$plist" 2>/dev/null || true
    rm -f "$plist"
    _info "autostart disabled for $repo"
  else
    _info "no autostart plist for $repo"
  fi
}

cmd_help() {
  cat <<'EOF'
claude-sandbox — Docker-isolated Claude Code, one container per repo.

Usage:
  claude-sandbox [PERM] [ISO] [repo]        start + attach (default mode)
  claude-sandbox start [PERM] [ISO] [repo]  start detached (no TTY)
  claude-sandbox new [PERM] [ISO] [--name X] [repo]
                                            force-create another parallel
                                            sandbox for this repo (auto-
                                            numbered: <base>, <base>-2, …)
  claude-sandbox attach [name]              attach to a running sandbox
                                            (fzf picker if multiple)
  claude-sandbox stop [--purge] [name]      stop & remove (cwd-scoped picker
  claude-sandbox stop --all-here              for cwd repo, with mode
  claude-sandbox stop --all                   --all-here / --all variants)
  claude-sandbox export [name]              --strict only: git-fetch volume
                                            branches into the host repo
                                            as refs/sandbox-export/*
  claude-sandbox list                       all sandboxes (with workspace col)
  claude-sandbox info                       image + sandbox status
  claude-sandbox rebuild                    docker build --no-cache
  claude-sandbox enable-autostart [repo]    LaunchAgent: start at login
  claude-sandbox disable-autostart [repo]
  claude-sandbox help

Naming:
  Containers: claude-sandbox-<base>[-mode][-name | -N]
    base   = sanitized repo basename
    mode   = -wt | -strict (default mode has no suffix)
    name   = sanitized --name X (named slot)
    N      = auto-bumped integer (parallel sessions; cross-repo collision)

  iOS labels: 🛡 <base>[-mode][-name | -N]   (or 🛡 <X> if --name X is set)

  Cross-repo basename collision: first repo to claim `<base>` wins; the
  second auto-bumps to `<base>-2`. Detected via the workspace label set
  on each container.

Permission modes (PERM):
  --bypass    (default) no permission prompts; the sandbox is the firewall
  --auto      acceptEdits mode; some prompts on high-risk operations

Isolation modes (ISO):
  (default)   bind-mount cwd as /workspace, ~/.claude RW.
              Risk: Claude can rm -rf the cwd; ~/.claude can be corrupted.
              Host filesystem outside those two mounts: 0% risk.

  --worktree  bind-mount a fresh `git worktree add` (under cache dir)
              instead of cwd. Main checkout is unreachable from the
              container. ~/.claude RW (same as default).
              Cheap "just in case" upgrade; one extra arg.

  --strict    /workspace is a docker volume seeded once from the cwd repo.
              ~/.claude is a docker volume seeded once from host ~/.claude.
              The long-running container has NO host bind mounts (except
              ~/.gitconfig RO for commit identity). Host repo and host
              ~/.claude cannot be touched by the container at all.
              Use `claude-sandbox export` to git-fetch changes back to
              the host repo as refs/sandbox-export/*; review and merge
              at your own pace.

Detach without stopping: Ctrl-p Ctrl-q.

Drive any running sandbox from your phone via claude.ai/code or the
Claude mobile app — `claude --remote-control` polls the Anthropic API
outbound; no inbound port is opened.
EOF
}

main() {
  local sub="${1:-}"
  case "$sub" in
    new)                shift; cmd_new "$@" ;;
    start)              shift; cmd_start "$@" ;;
    attach)             shift; cmd_attach "$@" ;;
    stop)               shift; cmd_stop "$@" ;;
    export)             shift; cmd_export "$@" ;;
    list|ls)            shift; cmd_list "$@" ;;
    info|status)        shift; cmd_info "$@" ;;
    rebuild)            shift; cmd_rebuild "$@" ;;
    enable-autostart)   shift; cmd_enable_autostart "$@" ;;
    disable-autostart)  shift; cmd_disable_autostart "$@" ;;
    help|-h|--help)     cmd_help ;;
    *)                  cmd_default "$@" ;;
  esac
}

main "$@"
