#!/usr/bin/env bash
# theme-fetch — download and verify theme assets referenced by manifests.
#
# Tool A of the dotfiles theme system. Runs occasionally: fresh machine
# bootstrap, upstream refresh, or after adding a new family. Reads manifests
# from $XDG_CONFIG_HOME/dotfiles/themes/<family>, downloads assets to
# $XDG_DATA_HOME/dotfiles/themes/<asset>/<family>-<variant>.<ext>, and tracks
# expected sha256 in a lockfile. No external dependencies — bash + curl +
# sha256sum/shasum + standard unix utilities.

set -euo pipefail

readonly _XDG_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}"
readonly _XDG_DATA="${XDG_DATA_HOME:-$HOME/.local/share}"
readonly _MANIFESTS="$_XDG_CONFIG/dotfiles/themes"
readonly _ASSETS="$_XDG_DATA/dotfiles/themes"
readonly _LOCK="$_ASSETS/.lock"

die() { printf 'theme-fetch: %s\n' "$*" >&2; exit 1; }
warn() { printf 'theme-fetch: %s\n' "$*" >&2; }

# ------------- manifest reader -------------
_manifest_get() {
  local file="$_MANIFESTS/$1" key="$2" line k v
  [[ -f "$file" ]] || return 1
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    k="${line%%=*}"
    v="${line#*=}"
    k="${k#"${k%%[![:space:]]*}"}"; k="${k%"${k##*[![:space:]]}"}"
    v="${v#"${v%%[![:space:]]*}"}"; v="${v%"${v##*[![:space:]]}"}"
    [[ "$k" == "$key" ]] && { printf '%s\n' "$v"; return 0; }
  done < "$file"
  return 1
}

_variants() {
  local raw v
  raw=$(_manifest_get "$1" variants) || return 1
  IFS=, read -ra v <<<"$raw"
  printf '%s\n' "${v[@]}" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

_families() {
  [[ -d "$_MANIFESTS" ]] || return 0
  local f
  for f in "$_MANIFESTS"/*; do
    [[ -f "$f" ]] || continue
    basename "$f"
  done | sort
}

# Discover asset names declared in a manifest (entries shaped asset.<NAME>.url).
_assets_for() {
  local file="$_MANIFESTS/$1" line k seen=""
  [[ -f "$file" ]] || return 1
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    k="${line%%=*}"
    k="${k#"${k%%[![:space:]]*}"}"; k="${k%"${k##*[![:space:]]}"}"
    if [[ "$k" =~ ^asset\.([^.]+)\.url$ ]]; then
      local asset="${BASH_REMATCH[1]}"
      if [[ ",$seen," != *",$asset,"* ]]; then
        seen="$seen,$asset"
        printf '%s\n' "$asset"
      fi
    fi
  done < "$file"
}

# ------------- helpers -------------
_apply_template() {
  local tmpl="$1" variant="$2" Variant
  Variant=$(printf '%s%s' "$(printf '%s' "${variant:0:1}" | tr '[:lower:]' '[:upper:]')" "${variant:1}")
  tmpl="${tmpl//\{variant\}/$variant}"
  tmpl="${tmpl//\{Variant\}/$Variant}"
  printf '%s\n' "$tmpl"
}

_url_extension() {
  local url="$1" tail
  tail="${url%%\?*}"
  tail="${tail##*/}"
  if [[ "$tail" == *.* ]]; then
    printf '%s\n' "${tail##*.}"
  else
    printf 'dat\n'
  fi
}

_target_path() {
  local family="$1" variant="$2" asset="$3" url="$4" ext
  ext=$(_url_extension "$url")
  printf '%s/%s/%s-%s.%s\n' "$_ASSETS" "$asset" "$family" "$variant" "$ext"
}

_sha256() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    die "neither sha256sum nor shasum is on PATH"
  fi
}

_download() {
  local url="$1" target="$2" tmp
  tmp="$target.tmp.$$"
  mkdir -p "$(dirname "$target")"
  if curl --fail --location --silent --show-error --max-time 30 --retry 2 -o "$tmp" "$url"; then
    mv "$tmp" "$target"
    return 0
  fi
  rm -f "$tmp"
  return 1
}

# ------------- lockfile -------------
_lock_get() {
  local key="$1"
  [[ -f "$_LOCK" ]] || return 1
  local line
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "$key="* ]]; then
      printf '%s\n' "${line#*=}"
      return 0
    fi
  done < "$_LOCK"
  return 1
}

_lock_set() {
  local key="$1" value="$2"
  mkdir -p "$(dirname "$_LOCK")"
  if [[ -f "$_LOCK" ]]; then
    grep -v "^${key}=" "$_LOCK" > "$_LOCK.tmp" 2>/dev/null || true
    mv "$_LOCK.tmp" "$_LOCK"
  fi
  printf '%s=%s\n' "$key" "$value" >> "$_LOCK"
  # Keep lockfile sorted for stable diffs
  sort -o "$_LOCK" "$_LOCK"
}

# ------------- iteration filter -------------
# Sets globals __filter_fam and __filter_var from a [family[/variant]] arg.
_parse_filter() {
  __filter_fam=""
  __filter_var=""
  local arg="${1:-}"
  [[ -z "$arg" ]] && return 0
  if [[ "$arg" == */* ]]; then
    __filter_fam="${arg%%/*}"
    __filter_var="${arg#*/}"
  else
    __filter_fam="$arg"
  fi
}

# Iterates every (family, variant, asset) tuple matching the current filter.
# Calls "$1 family variant asset url target key" for each.
_iter() {
  local cb="$1"
  local family variant asset url target key
  for family in $(_families); do
    [[ -n "$__filter_fam" && "$family" != "$__filter_fam" ]] && continue
    for variant in $(_variants "$family"); do
      [[ -n "$__filter_var" && "$variant" != "$__filter_var" ]] && continue
      for asset in $(_assets_for "$family"); do
        url=$(_apply_template "$(_manifest_get "$family" "asset.$asset.url")" "$variant")
        target=$(_target_path "$family" "$variant" "$asset" "$url")
        key="$family/$variant/$asset"
        "$cb" "$family" "$variant" "$asset" "$url" "$target" "$key"
      done
    done
  done
}

# ------------- subcommand callbacks -------------
__cb_install() {
  local family="$1" variant="$2" asset="$3" url="$4" target="$5" key="$6" sha expected
  if [[ -f "$target" ]]; then
    expected=$(_lock_get "$key" 2>/dev/null || true)
    if [[ -n "$expected" ]]; then
      sha=$(_sha256 "$target")
      if [[ "$sha" != "$expected" ]]; then
        warn "$key: sha mismatch — re-downloading"
        if _download "$url" "$target"; then
          sha=$(_sha256 "$target")
          if [[ "$sha" == "$expected" ]]; then
            printf '✓ %s (re-downloaded)\n' "$key"
          else
            warn "$key: re-download sha $sha != lockfile $expected"
          fi
        else
          warn "$key: re-download failed"
        fi
      else
        printf '✓ %s\n' "$key"
      fi
    else
      sha=$(_sha256 "$target")
      _lock_set "$key" "$sha"
      printf '✓ %s (recorded sha)\n' "$key"
    fi
  else
    if _download "$url" "$target"; then
      sha=$(_sha256 "$target")
      expected=$(_lock_get "$key" 2>/dev/null || true)
      if [[ -z "$expected" ]]; then
        _lock_set "$key" "$sha"
        printf '↓ %s (downloaded, recorded sha)\n' "$key"
      elif [[ "$sha" == "$expected" ]]; then
        printf '↓ %s (downloaded, sha matches)\n' "$key"
      else
        warn "$key: downloaded sha $sha != lockfile $expected"
      fi
    else
      warn "$key: download failed from $url"
    fi
  fi
}

__cb_refresh() {
  local family="$1" variant="$2" asset="$3" url="$4" target="$5" key="$6" sha
  if _download "$url" "$target"; then
    sha=$(_sha256 "$target")
    _lock_set "$key" "$sha"
    printf '↓ %s sha=%s\n' "$key" "$sha"
  else
    warn "$key: download failed from $url"
  fi
}

__cb_verify() {
  local family="$1" variant="$2" asset="$3" url="$4" target="$5" key="$6" sha expected
  if [[ ! -f "$target" ]]; then
    warn "$key: missing"
    __verify_ok=false
    return 0
  fi
  expected=$(_lock_get "$key" 2>/dev/null || true)
  if [[ -z "$expected" ]]; then
    warn "$key: no lockfile entry"
    __verify_ok=false
    return 0
  fi
  sha=$(_sha256 "$target")
  if [[ "$sha" != "$expected" ]]; then
    warn "$key: sha mismatch ($sha != $expected)"
    __verify_ok=false
  else
    printf '✓ %s\n' "$key"
  fi
}

# ------------- subcommands -------------
cmd_install() {
  _parse_filter "${1:-}"
  _iter __cb_install
}

cmd_refresh() {
  _parse_filter "${1:-}"
  _iter __cb_refresh
}

cmd_verify() {
  _parse_filter "${1:-}"
  __verify_ok=true
  _iter __cb_verify
  $__verify_ok || exit 1
}

cmd_list() {
  if [[ $# -eq 0 ]]; then
    _families
  else
    _variants "$1" || die "unknown family: $1"
  fi
}

cmd_help() {
  cat <<EOF
theme-fetch — download and verify theme assets

Usage:
  theme-fetch install [family[/variant]]   Download missing assets, record sha
  theme-fetch refresh [family[/variant]]   Force re-download, update lockfile
  theme-fetch verify  [family[/variant]]   Verify cached assets against lockfile
  theme-fetch list    [family]             List families or variants
  theme-fetch --help                       Show this help

Locations:
  manifests: $_MANIFESTS/<family>
  cache:     $_ASSETS/<asset>/<family>-<variant>.<ext>
  lockfile:  $_LOCK

For runtime theme switching, see theme.
EOF
}

case "${1:-}" in
  install)         shift 2>/dev/null || true; cmd_install "$@" ;;
  refresh)         shift 2>/dev/null || true; cmd_refresh "$@" ;;
  verify)          shift 2>/dev/null || true; cmd_verify "$@" ;;
  list)            shift 2>/dev/null || true; cmd_list "$@" ;;
  -h|--help|help)  cmd_help ;;
  "")              cmd_help ;;
  *)               die "unknown command: $1 (try 'theme-fetch --help')" ;;
esac
