#!/usr/bin/env bash
# dotfiles — chezmoi wrapper with status snapshot.
#
# `dotfiles` (no args) or `dotfiles info` prints a snapshot of the
# deployment: source dir, git state, chezmoi drift, theme, tool versions.
# Any other invocation forwards to `chezmoi` via `exec`. Some subcommands
# (currently `cd`) are overridden by shell-function wrappers in dot_zfunc/
# and dot_config/fish/functions/ to operate on the calling shell directly.

set -euo pipefail

# ANSI color helpers — only when stdout is a TTY.
if [[ -t 1 ]]; then
  C_DIM=$'\033[2m'
  C_BOLD=$'\033[1m'
  C_RESET=$'\033[0m'
else
  C_DIM=""
  C_BOLD=""
  C_RESET=""
fi

_row() {
  printf '%s%-7s%s %s\n' "$C_BOLD" "$1" "$C_RESET" "$2"
}

_version_of() {
  local out
  out=$("$1" --version 2>&1 | head -n1) || return 1
  printf '%s' "$out" | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -n1
}

cmd_info() {
  local source_dir=""
  if command -v chezmoi >/dev/null 2>&1; then
    source_dir=$(chezmoi source-path 2>/dev/null || true)
  fi
  [[ -n "$source_dir" ]] && _row "Repo:" "$source_dir"

  if [[ -n "$source_dir" && -d "$source_dir/.git" ]]; then
    local branch ahead behind
    branch=$(git -C "$source_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
    ahead=$(git -C "$source_dir" rev-list --count "@{u}..HEAD" 2>/dev/null || echo 0)
    behind=$(git -C "$source_dir" rev-list --count "HEAD..@{u}" 2>/dev/null || echo 0)
    _row "Branch:" "$branch (ahead $ahead, behind $behind)"
  fi

  if command -v chezmoi >/dev/null 2>&1; then
    local status_out
    status_out=$(chezmoi status 2>/dev/null || true)
    if [[ -z "$status_out" ]]; then
      _row "Drift:" "none"
    else
      local count
      count=$(printf '%s\n' "$status_out" | wc -l | tr -d ' ')
      _row "Drift:" "$count file(s)"
      # List each drifted entry on its own indented line. `chezmoi status`
      # emits `XY <path>` (X = source state, Y = target state — same shape
      # as `git status -s`). 8 leading spaces aligns with the _row value column.
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        printf '        %s%s%s\n' "$C_DIM" "$line" "$C_RESET"
      done <<<"$status_out"
    fi
  fi

  if command -v theme >/dev/null 2>&1; then
    _row "Theme:" "$(theme get 2>/dev/null || echo "?")"
  fi

  local tools=(chezmoi nvim fish zsh mise brew hive theme starship)
  local versions=()
  for t in "${tools[@]}"; do
    command -v "$t" >/dev/null 2>&1 || continue
    local v
    v=$(_version_of "$t" 2>/dev/null || echo "")
    if [[ -n "$v" ]]; then
      versions+=("$t $v")
    else
      versions+=("$t")
    fi
  done
  if (( ${#versions[@]} > 0 )); then
    _row "Tools:" "${C_DIM}${versions[*]}${C_RESET}"
  fi
}

cmd_help() {
  cat <<EOF
dotfiles — chezmoi wrapper with status snapshot

Usage:
  dotfiles                  Print info snapshot (default)
  dotfiles info             Same as default
  dotfiles install          Interactive menu to (re)run install steps
  dotfiles install all      Run every install step non-interactively
  dotfiles install <names>  Run only the named steps (e.g. brew mise)
  dotfiles sync             Review untracked packages and add/blacklist them
  dotfiles save [path]      Re-add drifted target files into the source dir
  dotfiles <cmd>            Forward to chezmoi (e.g. dotfiles apply, dotfiles diff)
  dotfiles --help           Show this help

Shell-function overrides (active in zsh and fish):
  dotfiles cd               cd current shell to chezmoi source dir
  dotfiles apply            Re-source shell rc file on successful apply

For chezmoi-specific help: chezmoi --help
EOF
}

# Hash a single file with sha256. Empty output for missing files.
_hash_file() {
  local f="$1"
  [[ -r "$f" ]] || { printf ''; return; }
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$f" | awk '{print $1}'
  else
    shasum -a 256 "$f" 2>/dev/null | awk '{print $1}'
  fi
}

cmd_save() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
dotfiles save — re-add changed target files into the chezmoi source dir.

Use this when something OTHER than your editor (an app, a `theme set`,
the OS) wrote into a managed file. For your own edits, prefer
`chezmoi edit <path>` — it skips the drift round-trip entirely.

Usage:
  dotfiles save              Inspect every drifted file and re-add the safe ones
  dotfiles save <path>       Re-add a specific path

Behavior per drifted file:
  • non-templated → `chezmoi re-add` runs
  • templated     → SKIPPED (re-add would clobber the template); use
                    `chezmoi edit` to edit the source instead
  • untracked     → SKIPPED with a hint to `chezmoi add <path>`
EOF
      return 0
      ;;
  esac

  command -v chezmoi >/dev/null 2>&1 || {
    printf 'dotfiles save: chezmoi not on PATH\n' >&2
    return 1
  }

  if [[ -n "${1:-}" ]]; then
    _save_one "$1"
    return $?
  fi

  local status_out
  status_out=$(chezmoi status 2>/dev/null || true)
  if [[ -z "$status_out" ]]; then
    printf 'no drift — source is up to date\n'
    return 0
  fi

  local added=0 skipped=0 templated=0
  local target_root
  target_root=$(chezmoi target-path 2>/dev/null || echo "$HOME")

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    # `chezmoi status` short format: "XY path" (2 status cols + space).
    local code="${line:0:2}"
    local rel="${line:3}"
    local path="$target_root/$rel"

    case "$code" in
      ' M'|' A'|' R')
        # Target diverged from rendered source — candidate for re-add.
        local src
        src=$(chezmoi source-path "$path" 2>/dev/null) || src=""
        if [[ "$src" == *.tmpl ]]; then
          printf '  %s%s%s  templated → use `chezmoi edit %s`\n' "$C_DIM" "$rel" "$C_RESET" "$path"
          templated=$((templated + 1))
          continue
        fi
        chezmoi re-add "$path" >/dev/null 2>&1
        printf '  %sre-added%s  %s\n' "$C_BOLD" "$C_RESET" "$rel"
        added=$((added + 1))
        ;;
      ' D')
        printf '  %s%s%s  target was deleted (run `chezmoi apply` to restore, or `chezmoi remove`)\n' "$C_DIM" "$rel" "$C_RESET"
        skipped=$((skipped + 1))
        ;;
      *)
        # Anything else (M*, A*, D*) means SOURCE changed — apply territory, not re-add.
        printf '  %s%s%s  source change pending → `chezmoi apply`\n' "$C_DIM" "$rel" "$C_RESET"
        skipped=$((skipped + 1))
        ;;
    esac
  done <<<"$status_out"

  printf '\n%d re-added, %d skipped (templated), %d skipped (other)\n' \
    "$added" "$templated" "$skipped"
}

# Re-add a single path. Refuses templated files and unmanaged paths.
_save_one() {
  local path="$1"
  # Resolve to absolute (chezmoi source-path needs that for accurate matching).
  if [[ "$path" != /* ]]; then
    path="$(cd "$(dirname "$path")" 2>/dev/null && pwd)/$(basename "$path")"
  fi

  local src
  src=$(chezmoi source-path "$path" 2>/dev/null) || {
    printf '%s is not managed by chezmoi.\n' "$path"
    printf 'to start managing it: chezmoi add %s\n' "$path"
    return 1
  }

  if [[ "$src" == *.tmpl ]]; then
    printf '%s is templated — re-add would clobber the template.\n' "$path"
    printf 'edit the source directly: chezmoi edit %s\n' "$path"
    return 1
  fi

  if chezmoi re-add "$path" >/dev/null 2>&1; then
    printf 're-added: %s\n' "$path"
  else
    printf 'chezmoi re-add failed for %s\n' "$path" >&2
    return 1
  fi
}

cmd_install() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
dotfiles install — interactive multi-select runner for install steps.

Usage:
  dotfiles install                  Open the menu (pre-checks items whose
                                    inputs have changed since the last run)
  dotfiles install all              Run every step non-interactively
  dotfiles install none             Run only required steps (skip everything else)
  dotfiles install <name> <name>…   Run the named steps (e.g. brew mise)

Inside the menu:
  ↑/↓ navigate · ←/→ jump column · space toggle · a/n select all/none
  / filter · enter run · q/esc cancel · ? help
EOF
      return 0
      ;;
  esac

  local os
  case "$(uname -s)" in
    Darwin) os=darwin ;;
    Linux)  os=linux  ;;
    *) printf 'dotfiles install: unsupported OS %s\n' "$(uname -s)" >&2; return 1 ;;
  esac

  local source_dir
  source_dir=$(chezmoi source-path 2>/dev/null) || {
    printf 'dotfiles install: chezmoi not found on PATH\n' >&2
    return 1
  }
  if [[ ! -r "$source_dir/etc/bash/lib/init.bash" ]]; then
    printf 'dotfiles install: source dir lacks expected lib (%s)\n' "$source_dir" >&2
    return 1
  fi

  # The lib functions weren't written for `set -euo pipefail`. Relax for
  # the duration of this command.
  set +e +u +o pipefail

  # shellcheck disable=SC1091
  source "$source_dir/etc/bash/lib/init.bash"
  case "$os" in
    darwin) import unix darwin brew mise hive pick ;;
    linux)  import unix linux mise extras hive pick ;;
  esac

  unix::keep_sudo

  # Translate positional args into DOTFILES_PICK so a non-interactive call
  # (e.g. `dotfiles install brew mise`) skips the menu and runs immediately.
  if (( $# > 0 )); then
    case "$1" in
      all|none) export DOTFILES_PICK="$1" ;;
      *)
        local IFS=','
        export DOTFILES_PICK="$*"
        ;;
    esac
  fi

  local mise_h hive_h
  mise_h=$(_hash_file "$source_dir/dot_config/mise/config.toml.tmpl")
  hive_h=$(_hash_file "$source_dir/dot_config/hive/config.toml.tmpl")

  local items=()
  case "$os" in
    darwin)
      darwin::require_clt || return 1
      local brew_h
      brew_h=$(_hash_file "$source_dir/etc/darwin/Brewfile")
      items=(
        "==Packages"
        "brew::setup=Homebrew packages & casks|$brew_h"
        "==Toolchains"
        "mise::setup=Language toolchains via mise|$mise_h"
        "==Workspace"
        "hive::setup=Workspace symlinks (hive)|$hive_h"
      )
      ;;
    linux)
      local distro pkg_file linux_h extras_h
      distro=$(linux::distro 2>/dev/null || echo unknown)
      pkg_file="$source_dir/etc/linux/packages-${distro}.txt"
      linux_h=$(_hash_file "$pkg_file")
      extras_h=$(_hash_file "$source_dir/etc/bash/lib/extras.bash")
      items=(
        "==Packages"
        "linux::setup=System packages (${distro})|$linux_h"
        "extras::setup=Bucket-3 tools (starship, gh, lazygit, …)|$extras_h"
        "==Toolchains"
        "mise::setup=Language toolchains via mise|$mise_h"
        "==Workspace"
        "hive::setup=Workspace symlinks (hive)|$hive_h"
      )
      ;;
  esac

  DOTFILES_PICK_SCOPE="install" pick "${items[@]}"
}

cmd_sync() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
dotfiles sync — review installed-but-untracked packages.

Diffs the system package manager's current state against
etc/<os>/packages.txt (and packages-blacklist.txt). For each untracked
entry, opens an interactive TUI where you assign one action per row:

  skip   — leave it alone
  add    — append `kind:name` to packages.txt (no profile annotation)
  @prof  — append `kind:name @profile` (profile-gated)
  block  — append to packages-blacklist.txt (sync won't surface again)

Inside the menu:
  ↑/↓ navigate · space cycle · a add · p add @personal · w add @work
  b blacklist · s skip · enter apply · q cancel · ? help
EOF
      return 0
      ;;
  esac

  local source_dir
  source_dir=$(chezmoi source-path 2>/dev/null) || {
    printf 'dotfiles sync: chezmoi not found on PATH\n' >&2
    return 1
  }
  set +e +u +o pipefail
  # shellcheck disable=SC1091
  source "$source_dir/etc/bash/lib/init.bash"
  import sync
  CHEZMOI_SOURCE_DIR="$source_dir" sync::run
}

case "${1:-}" in
  ""|info)
    shift 2>/dev/null || true
    cmd_info "$@"
    ;;
  -h|--help)
    cmd_help
    ;;
  install)
    shift
    cmd_install "$@"
    ;;
  sync)
    shift
    cmd_sync "$@"
    ;;
  save)
    shift
    cmd_save "$@"
    ;;
  help)
    if [[ $# -eq 1 ]]; then cmd_help; else exec chezmoi "$@"; fi
    ;;
  *)
    exec chezmoi "$@"
    ;;
esac
